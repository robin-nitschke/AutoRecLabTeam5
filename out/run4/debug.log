Running dataset={name}, users={df.user.nunique()}, items={df.item.nunique()}, interactions={len(df)}\')\n    for seed in SEEDS:\n        train, test = user_holdout(df, seed)\n        candidates = train[\'item\'].unique()\n        print(f\'Epoch {seed}: validation_loss = {float("nan"):.4f}\')\n        for alg_name, alg in build_algorithms().items():\n            alg.fit(train)\n            users = test[\'user\'].unique()\n            recs = batch.recommend(alg, users, 10, candidates=candidates)\n            if recs is None or len(recs) == 0:\n                continue\n            recs = recs[[\'user\', \'item\', \'rank\']].copy()\n            for k in KS:\n                p, nd = eval_recs(recs, test, k)\n                rows.append({\'dataset\': name, \'seed\': seed, \'algorithm\': alg_name, \'k\': k, \'precision\': p, \'ndcg\': nd})\n                experiment_data[name][\'metrics\'][\'val\'].append({\'seed\': seed, \'algorithm\': alg_name, \'k\': k, \'precision\': p, \'ndcg\': nd})\n            sample_pred = recs.head(100).to_dict(\'records\')\n            sample_truth = test.head(100).to_dict(\'records\')\n            experiment_data[name][\'predictions\'].append({\'seed\': seed, \'algorithm\': alg_name, \'data\': sample_pred})\n            experiment_data[name][\'ground_truth\'].append({\'seed\': seed, \'algorithm\': alg_name, \'data\': sample_truth})\n            experiment_data[name][\'losses\'][\'val\'].append({\'seed\': seed, \'algorithm\': alg_name, \'validation_loss\': np.nan})\n    return pd.DataFrame(rows)\n\n\ndatasets = {\n    \'ml100k\': load_ml100k(os.path.join(os.getcwd(), \'u.data\')),\n    \'amazon_vg\': load_amazon(os.path.join(os.getcwd(), \'VideoGames.csv\')),\n    \'lastfm\': load_lastfm(os.path.join(os.getcwd(), \'UserTaggedArtists-timestamps.dat\')),\n}\n\nall_results = pd.concat([run_dataset(name, df) for name, df in datasets.items()], ignore_index=True)\nsummary = all_results.groupby([\'dataset\', \'algorithm\', \'k\']).agg(\n    precision_mean=(\'precision\', \'mean\'), precision_std=(\'precision\', \'std\'),\n    ndcg_mean=(\'ndcg\', \'mean\'), ndcg_std=(\'ndcg\', \'std\')\n).reset_index()\nsummary[\'precision_cv\'] = summary[\'precision_std\'] / summary[\'precision_mean\'].replace(0, np.nan)\nsummary[\'ndcg_cv\'] = summary[\'ndcg_std\'] / summary[\'ndcg_mean\'].replace(0, np.nan)\n\nstats_rows = []\nfor (ds, alg, k), g in all_results.groupby([\'dataset\', \'algorithm\', \'k\']):\n    pvals = g[\'precision\'].values\n    ndvals = g[\'ndcg\'].values\n    f_p = stats.f_oneway(*[[x] for x in pvals]) if len(pvals) > 1 else (np.nan, np.nan)\n    f_n = stats.f_oneway(*[[x] for x in ndvals]) if len(ndvals) > 1 else (np.nan, np.nan)\n    stats_rows.append({\n        \'dataset\': ds, \'algorithm\': alg, \'k\': k,\n        \'precision_seed_std\': float(np.std(pvals, ddof=1)) if len(pvals) > 1 else 0.0,\n        \'ndcg_seed_std\': float(np.std(ndvals, ddof=1)) if len(ndvals) > 1 else 0.0,\n        \'precision_anova_F\': float(f_p.statistic) if hasattr(f_p, \'statistic\') else np.nan,\n        \'precision_anova_p\': float(f_p.pvalue) if hasattr(f_p, \'pvalue\') else np.nan,\n        \'ndcg_anova_F\': float(f_n.statistic) if hasattr(f_n, \'statistic\') else np.nan,\n        \'ndcg_anova_p\': float(f_n.pvalue) if hasattr(f_n, \'pvalue\') else np.nan,\n    })\nstat_df = pd.DataFrame(stats_rows)\n\nprint(\'\\nDetailed results:\')\nprint(all_results.to_string(index=False))\nprint(\'\\nSummary across seeds:\')\nprint(summary.to_string(index=False))\nprint(\'\\nSeed sensitivity statistics:\')\nprint(stat_df.to_string(index=False))\n\nfor ds in all_results[\'dataset\'].unique():\n    fig, axes = plt.subplots(1, 2, figsize=(10, 4))\n    sub = all_results[(all_results[\'dataset\'] == ds) & (all_results[\'k\'] == 10)]\n    for alg in sub[\'algorithm\'].unique():\n        g = sub[sub[\'algorithm\'] == alg].sort_values(\'seed\')\n        axes[0].errorbar(g[\'seed\'], g[\'precision\'], marker=\'o\', label=alg)\n        axes[1].errorbar(g[\'seed\'], g[\'ndcg\'], marker=\'o\', label=alg)\n    axes[0].set_title(f\'{ds} Precision@10 across seeds\')\n    axes[1].set_title(f\'{ds} nDCG@10 across seeds\')\n    for ax in axes:\n        ax.set_xlabel(\'seed\')\n        ax.legend()\n    plt.tight_layout()\n    fig_path = os.path.join(working_dir, f\'{ds}_seed_variability.png\')\n    plt.savefig(fig_path, dpi=150)\n    plt.close(fig)\n\nnp.save(os.path.join(working_dir, \'experiment_data.npy\'), experiment_data, allow_pickle=True)\nnp.save(os.path.join(working_dir, \'all_results.npy\'), all_results.to_dict(\'records\'), allow_pickle=True)\nnp.save(os.path.join(working_dir, \'summary.npy\'), summary.to_dict(\'records\'), allow_pickle=True)\nnp.save(os.path.join(working_dir, \'stats.npy\'), stat_df.to_dict(\'records\'), allow_pickle=True)\n\n```', 'Execution Output': '```\nRunning dataset=ml100k, users=938, items=1008, interactions=54413\nEpoch 1: validation_loss = nan\nNumba is using threading layer omp - consider TBB\nfound 1 potential runtime problems - see https://boi.st/lkpy-perf\nTraceback (most recent call last):\n  File "C:\\Users\\Robin\\Documents\\GitHub\\AutoRecLabTeam5\\treesearch\\interpreter.py", line 147, in _run_session\n    exec(compile(code, self.agent_file_name, "exec"), global_scope)\n  File "runfile.py", line 139, in <module>\n    all_results = pd.concat([run_dataset(name, df) for name, df in datasets.items()], ignore_index=True)\n                            ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n  File "runfile.py", line 139, in <listcomp>\n    all_results = pd.concat([run_dataset(name, df) for name, df in datasets.items()], ignore_index=True)\n                             ^^^^^^^^^^^^^^^^^^^^^\n  File "runfile.py", line 117, in run_dataset\n    recs = batch.recommend(alg, users, 10, candidates=candidates)\n           ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n  File "C:\\Users\\Robin\\AppData\\Local\\Programs\\Python\\Python311\\Lib\\site-pack