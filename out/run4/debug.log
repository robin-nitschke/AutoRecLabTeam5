tem\']].astype(str).to_records(index=False))\\n    return udf\\n\\n\\ndatasets = {\\n    \'ml100k\': load_ml100k(\'u.data\'),\\n    \'amazon_videogames\': load_amazon(\'VideoGames.csv\'),\\n    \'lastfm\': load_lastfm(\'UserTaggedArtists-timestamps.dat\'),\\n}\\n\\nall_user_metrics, all_seed_metrics, prep_rows = [], [], []\\nfor dname, df in datasets.items():\\n    df, dropped_inter, dropped_users = drop_low_users(df)\\n    prep_rows.append({\'dataset\': dname, \'timestamp\': TS, \'after_kcore_interactions\': len(datasets[dname]), \'after_user_ge2_interactions\': len(df), \'dropped_interactions_low_user\': dropped_inter, \'dropped_users_low_user\': dropped_users})\\n    print(f\\"{dname}: usable after split check -> interactions={len(df)}, users={df.user.nunique()}, items={df.item.nunique()}, dropped_users_lt2={dropped_users}\\")\\n    for seed in SEEDS:\\n        train, test, excluded = user_holdout_split(df, 0.2, seed)\\n        experiment_data[dname][\'metrics\'][\'train\'].append({\'timestamp\': TS, \'seed\': seed, \'n_train\': len(train), \'n_test\': len(test), \'excluded_users\': excluded})\\n        algos = get_algorithms(seed)\\n        for aname, algo in algos.items():\\n            udf = evaluate_model(algo, train, test, aname, dname, seed)\\n            all_user_metrics.append(udf)\\n            s = udf[[f\'P@{k}\' for k in KS] + [f\'nDCG@{k}\' for k in KS]].mean().to_dict()\\n            s.update({\'dataset\': dname, \'algorithm\': aname, \'seed\': seed, \'timestamp\': TS})\\n            all_seed_metrics.append(s)\\n\\nuser_metrics_df = pd.concat(all_user_metrics, ignore_index=True)\\nseed_metrics_df = pd.DataFrame(all_seed_metrics)\\nprep_df = pd.DataFrame(prep_rows)\\n\\nmetric_cols = [f\'P@{k}\' for k in KS] + [f\'nDCG@{k}\' for k in KS]\\nagg = seed_metrics_df.groupby([\'dataset\', \'algorithm\'])[metric_cols].agg([\'mean\', \'std\', \'min\', \'max\'])\\nprint(\'\\\\nAggregate results over seeds (mean/std/min/max):\')\\nprint(agg.round(4))\\n\\nstats