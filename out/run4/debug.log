os.makedirs(working_dir, exist_ok=True)\\n\\nimport warnings\\nwarnings.filterwarnings(\'ignore\')\\n\\nimport inspect\\nimport numpy as np\\nimport pandas as pd\\nfrom scipy.stats import ttest_rel, t\\n\\nfrom lenskit import batch\\nfrom lenskit.algorithms import Recommender\\nfrom lenskit.algorithms.basic import Popular\\nfrom lenskit.algorithms.als import ImplicitMF\\nfrom lenskit.algorithms.item_knn import ItemItem\\n\\nSEEDS = [1, 7, 21, 42, 84]\\nKS = [1, 5, 10]\\n\\nexperiment_data = {\\n    \'ml100k\': {\'metrics\': {\'train\': [], \'val\': []}, \'losses\': {\'train\': [], \'val\': []}, \'predictions\': [], \'ground_truth\': []},\\n    \'amazon_videogames\': {\'metrics\': {\'train\': [], \'val\': []}, \'losses\': {\'train\': [], \'val\': []}, \'predictions\': [], \'ground_truth\': []},\\n    \'lastfm\': {\'metrics\': {\'train\': [], \'val\': []}, \'losses\': {\'train\': [], \'val\': []}, \'predictions\': [], \'ground_truth\': []},\\n}\\n\\n\\ndef _safe_read_csv(path, **kwargs):\\n    kwargs = dict(kwargs)\\n    kwargs.setdefault(\'on_bad_lines\', \'skip\')\\n    try:\\n        return pd.read_csv(path, **kwargs)\\n    except TypeError:\\n        kwargs.pop(\'on_bad_lines\', None)\\n        return pd.read_csv(path, **kwargs)\\n\\n\\ndef iterative_k_core(df, user_col=\'user\', item_col=\'item\', min_uc=5, min_ic=5):\\n    cur = df[[user_col, item_col]].dropna().drop_duplicates().copy()\\n    changed = True\\n    while changed and len(cur):\\n        ucnt = cur[user_col].value_counts()\\n        icnt = cur[item_col].value_counts()\\n        keep_u = set(ucnt[ucnt >= min_uc].index)\\n        keep_i = set(icnt[icnt >= min_ic].index)\\n        new = cur[cur[user_col].isin(keep_u) & cur[item_col].isin(keep_i)].copy()\\n        changed = len(new) != len(cur)\\n        cur = new\\n    return cur.reset_index(drop=True)\\n\\n\\ndef preprocess_summary(name, raw_rows, after_threshold_rows, dedup_rows, final_df, dropped_low_users):\\n    msg = (\\n        f\'{name}: raw_ro