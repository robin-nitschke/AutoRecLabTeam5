ing\'] > 3][[\'user\', \'item\']].copy()\\n    after_threshold_rows = len(df)\\n    df[\'user\'] = df[\'user\'].astype(str)\\n    df[\'item\'] = df[\'item\'].astype(str)\\n    dedup_rows = len(df.drop_duplicates())\\n    df = iterative_k_core(df)\\n    low_users = (df[\'user\'].value_counts() < 2).sum()\\n    return df, preprocess_summary(\'amazon_videogames\', raw_rows, after_threshold_rows, dedup_rows, df, low_users)\\n\\n\\ndef load_lastfm(path=\'UserTaggedArtists-timestamps.dat\'):\\n    df = _safe_read_csv(path, sep=\'\\\\t\')\\n    raw_rows = len(df)\\n    cols = {c.lower(): c for c in df.columns}\\n    user_col = cols.get(\'userid\', df.columns[0])\\n    item_col = cols.get(\'artistid\', df.columns[1])\\n    df = df[[user_col, item_col]].copy()\\n    df.columns = [\'user\', \'item\']\\n    df = df.dropna(subset=[\'user\', \'item\'])\\n    after_threshold_rows = len(df)\\n    df[\'user\'] = df[\'user\'].astype(str)\\n    df[\'item\'] = df[\'item\'].astype(str)\\n    dedup_rows = len(df.drop_duplicates())\\n    df = iterative_k_core(df)\\n    low_users = (df[\'user\'].value_counts() < 2).sum()\\n    return df, preprocess_summary(\'lastfm\', raw_rows, after_threshold_rows, dedup_rows, df, low_users)\\n\\n\\ndef user_holdout_split(df, test_ratio=0.2, seed=42):\\n    rng = np.random.default_rng(seed)\\n    vc = df[\'user\'].value_counts()\\n    valid_users = vc[vc >= 2].index\\n    dropped = int((vc < 2).sum())\\n    dfx = df[df[\'user\'].isin(valid_users)].copy()\\n    train_parts, test_parts = [], []\\n    for _, g in dfx.groupby(\'user\', sort=False):\\n        n = len(g)\\n        n_test = max(1, int(np.floor(n * test_ratio)))\\n        n_test = min(n_test, n - 1)\\n        idx = np.arange(n)\\n        rng.shuffle(idx)\\n        test_idx = idx[:n_test]\\n        mask = np.zeros(n, dtype=bool)\\n        mask[test_idx] = True\\n        train_parts.append(g.iloc[~mask])\\n        test_parts.append(g.iloc[mask])\\n    train = pd.concat(train_parts, ignore_index=True)\\n    test = pd.concat(test_parts, ignore_index=True)\\n    return train, test, dropped\\n\\n\\ndef adapt_algo(algo):\\n    return Recommender.adapt(algo)\\n\\n\\ndef get_algorithms(seed):\\n    sig = inspect.signature(ImplicitMF)\\n    als_kwargs = {}\\n    if \'random_state\' in sig.parameters:\\n        als_kwargs[\'random_state\'] = seed\\n    elif \'rng_spec\' in sig.parameters:\\n        als_kwargs[\'rng_spec\'] = seed\\n    als = ImplicitMF(**als_kwargs)\\n    itemknn = ItemItem(20)\\n    return {\\n        \'ALS\': adapt_algo(als),\\n        \'ItemKNN\': adapt_algo(itemknn),\\n        \'Pop\': adapt_algo(Popular()),\\n    }\\n\\n\\ndef precision_at_k(recs, truth, k):\\n    recs = recs[:k]\\n    if k == 0:\\n        return 0.0\\n    return sum(1 for x in recs if x in truth) / k\\n\\n\\ndef ndcg_at_k(recs, truth, k):\\n    recs = recs[:k]\\n    if not truth:\\n        return 0.0\\n    dcg = sum((1.0 / np.log2(i + 2)) for i, item in enumerate(recs) if item in truth)\\n    ideal = min(len(truth), k)\\n    idcg = sum(1.0 / np.log2(i + 2) for i in range(ideal))\\n    return 0.0 if idcg == 0 else dcg / idcg\\n\\n\\ndef evaluate_model(model, train, test, algo_name, dataset_name, seed):\\n    model.fit(train)\\n    users = test[\'user\'].drop_duplicates().tolist()\\n    truth = test.groupby(\'user\')[\'item\'].apply(set).to_dict()\\n    train_seen = train.groupby(\'user\')[\'item\'].apply(set).to_dict()\\n    recs = batch.recommend(model, users, 10)\\n    if recs is None or len(recs) == 0:\\n        recs = pd.DataFrame(columns=[\'user\', \'item\', \'rank\', \'score\'])\\n    if \'item\' in recs.columns and \'user\' in recs.columns:\\n        recs = recs[~recs.apply(lambda r: r[\'item\'] in train_seen.get(r[\'user\'], set()), axis=1)].copy()\\n        recs = recs.sort_values([\'user\', \'rank\'] if \'rank\' in recs.columns else [\'user\']).groupby(\'user\').head(10)\\n    user_recs = recs.groupby(\'user\')[\'item\'].apply(list).to_dict() if len(recs) else {}\\n\\n