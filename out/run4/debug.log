s[\'dataset\'].unique():\\n    fig, axes = plt.subplots(1, 2, figsize=(10, 4))\\n    sub = all_results[(all_results[\'dataset\'] == ds) & (all_results[\'k\'] == 10)]\\n    for alg in sub[\'algorithm\'].unique():\\n        g = sub[sub[\'algorithm\'] == alg].sort_values(\'seed\')\\n        axes[0].errorbar(g[\'seed\'], g[\'precision\'], marker=\'o\', label=alg)\\n        axes[1].errorbar(g[\'seed\'], g[\'ndcg\'], marker=\'o\', label=alg)\\n    axes[0].set_title(f\'{ds} Precision@10 across seeds\')\\n    axes[1].set_title(f\'{ds} nDCG@10 across seeds\')\\n    for ax in axes:\\n        ax.set_xlabel(\'seed\')\\n        ax.legend()\\n    plt.tight_layout()\\n    fig_path = os.path.join(working_dir, f\'{ds}_seed_variability.png\')\\n    plt.savefig(fig_path, dpi=150)\\n    plt.close(fig)\\n\\nnp.save(os.path.join(working_dir, \'experiment_data.npy\'), experiment_data, allow_pickle=True)\\nnp.save(os.path.join(working_dir, \'all_results.npy\'), all_results.to_dict(\'records\'), allow_pickle=True)\\nnp.save(os.path.join(working_dir, \'summary.npy\'), summary.to_dict(\'records\'), allow_pickle=True)\\nnp.save(os.path.join(working_dir, \'stats.npy\'), stat_df.to_dict(\'records\'), allow_pickle=True)\\n"}', name='return_plan_and_code'), type='function')]))[/cyan]
