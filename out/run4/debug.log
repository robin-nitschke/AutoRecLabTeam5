gorithms.basic import Popular\nfrom lenskit.algorithms.als import ImplicitMF\nfrom lenskit.algorithms.item_knn import ItemItem\n\nSEEDS = [1, 7, 21, 42, 84]\nKS = [1, 5, 10]\n\nexperiment_data = {\n    \'ml100k\': {\'metrics\': {\'train\': [], \'val\': []}, \'losses\': {\'train\': [], \'val\': []}, \'predictions\': [], \'ground_truth\': [], \'preprocess\': []},\n    \'amazon_videogames\': {\'metrics\': {\'train\': [], \'val\': []}, \'losses\': {\'train\': [], \'val\': []}, \'predictions\': [], \'ground_truth\': [], \'preprocess\': []},\n    \'lastfm\': {\'metrics\': {\'train\': [], \'val\': []}, \'losses\': {\'train\': [], \'val\': []}, \'predictions\': [], \'ground_truth\': [], \'preprocess\': []},\n}\n\n\ndef robust_read_csv(path, **kwargs):\n    kwargs = dict(kwargs)\n    kwargs.setdefault(\'on_bad_lines\', \'skip\')\n    try:\n        return pd.read_csv(path, **kwargs)\n    except TypeError:\n        kwargs.pop(\'on_bad_lines\', None)\n        return pd.read_csv(path, error_bad_lines=False, warn_bad_lines=False, **kwargs)\n\n\ndef standardize_pairs(df, user_col, item_col):\n    out = df[[user_col, item_col]].copy()\n    out.columns = [\'user\', \'item\']\n    out[\'user\'] = out[\'user\'].astype(str).str.strip()\n    out[\'item\'] = out[\'item\'].astype(str).str.strip()\n    out = out.replace({\'\': np.nan, \'nan\': np.nan, \'None\': np.nan})\n    out = out.dropna().drop_duplicates().reset_index(drop=True)\n    return out\n\n\ndef k_core_filter(df, user_col=\'user\', item_col=\'item\', min_uc=5, min_ic=5):\n    cur = df[[user_col, item_col]].drop_duplicates().copy()\n    while True:\n        uc = cur[user_col].value_counts()\n        ic = cur[item_col].value_counts()\n        keep_u = set(uc[uc >= min_uc].index)\n        keep_i = set(ic[ic >= min_ic].index)\n        new = cur[cur[user_col].isin(keep_u) & cur[item_col].isin(keep_i)].copy()\n        if len(new) == len(cur):\n            break\n        cur = new\n    return cur.reset_index(drop=True)\n\n\ndef load_ml100k(path=\'u.data\'):\n    raw = robust_read_csv(path, sep=\'\\t\', header=None, names=[\'user\', \'item\', \'rating\', \'timestamp\'])\n    raw[\'rating\'] = pd.to_numeric(raw[\'rating\'], errors=\'coerce\')\n    raw = raw.dropna(subset=[\'user\', \'item\', \'rating\'])\n    pre_n = len(raw)\n    raw = raw[raw[\'rating\'] > 3]\n    pairs = standardize_pairs(raw, \'user\', \'item\')\n    filtered = k_core_filter(pairs)\n    summary = {\n        \'raw_rows\': int(pre_n), \'after_threshold\': int(len(pairs)), \'after_kcore\': int(len(filtered)),\n        \'users\': int(filtered.user.nunique()), \'items\': int(filtered.item.nunique()), \'dropped_rows\': int(pre_n - len(filtered))\n    }\n    return filtered, summary\n\n\ndef load_amazon(path=\'VideoGames.csv\'):\n    raw = robust_read_csv(path, header=None)\n    if raw.shape[1] < 3:\n        raise ValueError(\'VideoGames.csv must have at least 3 columns\')\n    raw = raw.iloc[:, :4].copy()\n    cols = [\'user\', \'item\', \'rating\', \'timestamp\'][:raw.shape[1]]\n    raw.columns = cols\n    raw[\'rating\'] = pd.to_numeric(raw[\'rating\'], errors=\'coerce\')\n    raw = raw.dropna(subset=[\'user\', \'item\', \'rating\'])\n    pre_n = len(raw)\n    raw = raw[raw[\'rating\'] > 3]\n    pairs = standardize_pairs(raw, \'user\', \'item\')\n    filtered = k_core_filter(pairs)\n    summary = {\n        \'raw_rows\': int(pre_n), \'after_threshold\': int(len(pairs)), \'after_kcore\': int(len(filtered)),\n        \'users\': int(filtered.user.nunique()), \'items\': int(filtered.item.nunique()), \'dropped_rows\': int(pre_n - len(filtered))\n    }\n    return filtered, summary\n\n\ndef load_lastfm(path=\'UserTaggedArtists-timestamps.dat\'):\n    raw = robust_read_csv(path, sep=\'\\t\')\n    cols = {c.lower(): c for c in raw.columns}\n    user_col = cols[\'userid\'] if \'userid\' in cols else raw.columns[0]\n    item_col = cols[\'artistid\'] if \'artistid\' in cols else raw.columns[1]\n    raw = raw.dropna(subset=[user_col, item_col])\n    pre_n = len(raw)\n    pairs = standardize_pairs(raw, user_col, item_col)\n    filtered = k_core_filter(pairs)\n    summary = {\n        \'raw_rows\': int(pre_n), \'after_threshold\': int(len(pairs)), \'after_kcore\': int(len(filtered)),\n        \'users\': int(filtered.user.nunique()), \'items\': int(filtered.item.nunique()), \'dropped_rows\': int(pre_n - len(filtered))\n    }\n    return filtered, summary\n\n\ndef user_holdout_split(df, test_ratio=0.2, seed=42):\n    rng = np.random.default_rng(seed)\n    user_sizes = df.groupby(\'user\').size()\n    valid_users = user_sizes[user_sizes >= 2].index\n    excluded_users = int((user_sizes < 2).sum())\n    df = df[df[\'user\'].isin(valid_users)].copy()\n    train_parts, test_parts = [], []\n    for _, g in df.groupby(\'user\', sort=False):\n        n = len(g)\n        n_test = max(1, int(np.floor(n * test_ratio)))\n        if n_test >= n:\n            n_test = n - 1\n        idx = np.arange(n)\n        rng.shuffle(idx)\n        test_idx = idx[:n_test]\n        mask = np.zeros(n, dtype=bool)\n        mask[test_idx] = True\n        train_parts.append(g.iloc[~mask])\n        test_parts.append(g.iloc[mask])\n    train = pd.concat(train_parts, ignore_index=True)\n    test = pd.concat(test_parts, ignore_index=True)\n    return train, test, excluded_users\n\n\ndef make_algo(name, seed):\n    if name == \'Pop\':\n        return Recommender.adapt(Popular())\n    if name == \'ALS\':\n        params = inspect.signature(ImplicitMF).parameters\n        kwargs = {}\n        if \'random_state\' in params:\n            kwargs[\'random_state\'] = seed\n        return Recommender.adapt(ImplicitMF(**kwargs))\n    if name == \'ItemKNN\':\n        params = inspect.signature(ItemItem).parameters\n        kwargs = {}\n        if \'feedback\' in params:\n            kwargs[\'feedback\'] = \'implicit\'\n        return Recommender.adapt(ItemItem(**kwargs))\n    raise ValueError(name)\n\n\ndef precision_at_k(recs, truth, k):\n    recs = recs[:k]\n    return sum(1 for x in recs if x in truth) / k if k else 0.0\n\n\ndef ndcg_at_k(recs, truth, k):\n    recs = recs[:k]\n    dcg = sum((1.0 / np.log2(i + 2)) for i, x in enumerate(recs) if x in truth)\n    ideal = min(len(truth), k)\n    if ideal == 0:\n        return 0.0\n    idcg = sum(1.0 / np.log2(i + 2) for i in range(ideal))\n    return dcg / idcg\n\n\ndef evaluate_model(model, train, test, algo_name, dataset_name, seed):\n    model.fit(train)\n    users = np.array(sorted(test[\'user\'].unique()))\n    truth = test.groupby(\'user\')[\'item\'].apply(set).to_dict()\n    seen = train.groupby(\'user\')[\'item\'].apply(set).to_dict()\n    recs = batch.recommend(model, users, 50)\n    if recs is None or len(recs) == 0:\n        recs = pd.DataFrame(columns=[\'user\', \'item\', \'rank\', \'score\'])\n    recs = recs[~recs.apply(lambda r: r[\'item\'] in seen.get(r[\'user\'], set()), axis=1)].copy()\n    recs[\'rank2\'] = recs.groupby(\'user\').cumcount() + 1\n    recs = recs[recs[\'rank2\'] <= 10].drop(columns=[\'rank2\'])\n    user_recs = recs.groupby(\'user\')[\'item\'].apply(list).to_dict()\n\n    rows = []\n    for u in users:\n        r = user_recs.get(u, [])\n        tset = truth.get(u, set())\n        row = {\'dataset\': dataset_name, \'algorithm\': algo_name, \'seed\': seed, \'user\': u}\n        for k in KS:\n            row[f\'P@{k}\'] = precision_at_k(r, tset, k)\n            row[f\'nDCG@{k}\'] = ndcg_at_k(r, tset, k)\n        rows.append(row)\n    udf = pd.DataFrame(rows)\n    summary = {\'dataset\': dataset_name, \'algorithm\': algo_name, \'seed\': seed}\n    for c in [f\'P@{k}\' for k in KS] + [f\'nDCG@{k}\' for k in KS]:\n        summary[c] = float(udf[c].mean())\n    val_loss = 1.0 - summary[\'nDCG@10\']\n    print(f\'Seed {seed} | {dataset_name} | {algo_name} | validation_loss = {val_loss:.4f}\')\n    print({k: round(v, 4) for k, v in summary.items() if k not in [\'dataset\', \'algorithm\', \'seed\']})\n\n    experiment_data[dataset_name][\'