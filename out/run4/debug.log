= {c.lower(): c for c in df.columns}\n    user_col = cols.get('userid', df.columns[0])\n    item_col = cols.get('artistid', df.columns[1])\n    df = df[[user_col, item_col]].copy()\n    df.columns = ['user', 'item']\n    df = df.dropna(subset=['user', 'item'])\n    after_threshold_rows = len(df)\n    df['user'] = df['user'].astype(str)\n    df['item'] = df['item'].astype(str)\n    dedup_rows = len(df.drop_duplicates())\n    df = iterative_k_core(df)\n    low_users = (df['user'].value_counts() < 2).sum()\n    return df, preprocess_summary('lastfm', raw_rows, after_threshold_rows, dedup_rows, df, low_users)\n\n\ndef user_holdout_split(df, test_ratio=0.2, seed=42):\n    rng = np.random.default_rng(seed)\n    vc = df['user'].value_counts()\n    valid_users = vc[vc >= 2].index\n    dropped = int((vc < 2).sum())\n    dfx = df[df['user'].isin(valid_users)].copy()\n    train_parts, test_parts = [], []\n    for _, g in dfx.groupby('user', sort=False):\n        n = len(g)\n        n_test = max(1, int(np.floor(n * test_ratio)))\n        n_test = min(n_test, n - 1)\n        idx = np.arange(n)\n        rng.shuffle(idx)\n        test_idx = idx[:n_test]\n        mask = np.zeros(n, dtype=bool)\n        mask[test_idx] = True\n        train_parts.append(g.iloc[~mask])\n        test_parts.append(g.iloc[mask])\n    train = pd.concat(train_parts, ignore_index=True)\n    test = pd.concat(test_parts, ignore_index=True)\n    return train, test, dropped\n\n\ndef adapt_algo(algo):\n    return Recommender.adapt(algo)\n\n\ndef get_algorithms(seed):\n    sig = inspect.signature(ImplicitMF)\n    als_kwargs = {}\n    if 'random_state' in sig.parameters:\n        als_kwargs['random_state'] = seed\n    elif 'rng_spec' in sig.parameters:\n        als_kwargs['rng_spec'] = seed\n    als = ImplicitMF(**als_kwargs)\n    itemknn = ItemItem(20)\n    return {\n        'ALS': adapt_algo(als),\n        'ItemKNN': adapt_algo(itemknn),\n        'Pop': adapt_algo(Popular()),\n    }\n\n\ndef precision_at_k(recs, truth, k):\n    recs = recs[:k]\n    if k == 0:\n        return 0.0\n    return sum(1 for x in recs if x in truth) / k\n\n\ndef ndcg_at_k(recs, truth, k):\n    recs = recs[:k]\n    if not truth:\n        return 0.0\n    dcg = sum((1.0 / np.log2(i + 2)) for i, item in enumerate(recs) if item in truth)\n    ideal = min(len(truth), k)\n    idcg = sum(1.0 / np.log2(i + 2) for i in range(ideal))\n    return 0.0 if idcg == 0 else dcg / idcg\n\n\ndef evaluate_model(model, train, test, algo_name, dataset_name, seed):\n    model.fit(train)\n    users = test['user'].drop_duplicates().tolist()\n    truth = test.groupby('user')['item'].apply(set).to_dict()\n    train_seen = train.groupby('user')['item'].apply(set).to_dict()\n    recs = batch.recommend(model, users, 10)\n    if recs is None or len(recs) == 0:\n        recs = pd.DataFrame(columns=['user', 'item', 'rank', 'score'])\n    if 'item' in recs.columns and 'user' in recs.columns:\n        recs = recs[~recs.apply(lambda r: r['item'] in train_seen.get(r['user'], set()), axis=1)].copy()\n        recs = recs.sort_values(['user', 'rank'] if 'rank' in recs.columns else ['user']).groupby('user').head(10)\n    user_recs = recs.groupby('user')['item'].apply(list).to_dict() if len(recs) else {}\n\n    rows = []\n    for u in users:\n        pred = user_recs.get(u, [])\n        gt = truth.get(u, set())\n        row = {'dataset': dataset_name, 'algorithm': algo_name, 'seed': seed, 'user': u}\n        for k in KS:\n            row[f'P@{k}'] = precision_at_k(pred, gt, k)\n            row[f'nDCG@{k}'] = ndcg_at_k(pred, gt, k)\n        rows.append(row)\n    udf = pd.DataFrame(rows)\n    metric_cols = [f'P@{k}' for k in KS] + [f'nDCG@{k}' for k in KS]\n    summary = udf[metric_cols].mean().to_dict()\n    val_loss = 1 - summary['nDCG@10']\n    print(f'Seed {seed} | {dataset_name} | {algo_name} | validation_loss = {val_loss:.4f}')\n    print({k: round(v, 4) for k, v in summary.items()})\n\n    experiment_data[dataset_name]['metrics']['val'].append({'seed': seed, 'algorithm': algo_name, **summary})\n    experiment_data[dataset_name]['losses']['val'].append({'seed': seed, 'algorithm': algo_name, 'validation_loss': val_loss})\n    experiment_data[dataset_name]['predictions'].append({'seed': seed, 'algorithm': algo_name, 'records': recs[['user', 'item']].to_dict('records') if len(recs) else []})\n    experiment_data[dataset_name]['ground_truth'].append({'seed': seed, 'algorithm': algo_name, 'records': test[['user', 'item']].to_dict('records')})\n    return udf\n\n\ndef paired_ci(x, y, alpha=0.05):\n    d = np.asarray(x) - np.asarray(y)\n    n = len(d)\n    mean = d.mean()\n    if n < 2:\n        return mean, np.nan, np.nan\n    se = d.std(ddof=1) / np.sqrt(n)\n    crit = t.ppf(1 - alpha / 2, df=n - 1)\n    return mean, mean - crit * se, mean + crit * se\n\n\ndatasets = {}\npre_rows = []\nfor name, loader, path in [\n    ('ml100k', load_ml100k, 'u.data'),\n    ('amazon_videogames', load_amazon, 'VideoGames.csv'),\n    ('lastfm', load_lastfm, 'UserTaggedArtists-timestamps.dat'),\n]:\n    df, summary = loader(path)\n    datasets[name] = df\n    pre_rows.append(summary)\n\npre_df = pd.DataFrame(pre_rows)\npre_df.to_csv(os.path.join(working_dir, 'preprocessing_summary.csv'), index=False)\nnp.save(os.path.join(working_dir, 'preprocessing_summary.npy'), pre_df.to_dict('records'), allow_pickle=True)\n\nall_user_metrics = []\nall_seed_metrics = []\n\nfor dname, df in datasets.items():\n    print(f'Loaded {dname}: interactions={len(df)}, users={df.user.nunique()}, items={df.item.nunique()}')\n    for seed in SEEDS:\n        train, test, dropped = user_holdout_split(df, test_ratio=0.2, seed=seed)\n        experiment_data[dname]['metrics']['train'].append({\n            'seed': seed,\n            'n_train': int(len(train)),\n            'n_test': int(len(test)),\n            'n_users_train': int(train.user.nunique()),\n            'n_users_test': int(test.user.nunique()),\n            'dropped_users_lt2_before_split': int(dropped),\n        })\n        algos = get_algorithms(seed)\n        for aname, algo in algos.items():\n            udf = evaluate_model(algo, train, test, aname, dname, seed)\n            all_user_metrics.append(udf)\n            means = udf.drop(columns=['user']).mean(numeric_only=True).to_dict()\n            means.update({'dataset': dname, 'algorithm': aname, 'seed': seed})\n            all_seed_metrics.append(means)\n\nuser_metrics_df = pd.concat(all_user_metrics, ignore_index=True)\nseed_metrics_df = pd.DataFrame(all_seed_metrics)\n\nmetric_cols = [f'P@{k}' for k in KS] + [f'nDCG@{k}' for k in KS]\nagg = seed_metrics_df.groupby(['dataset', 'algorithm'])[metric_cols].agg(['mean', 'std', 'min', 'max'])\nrange_df = seed_metrics_df.groupby(['dataset', 'algorithm'])[metric_cols].agg(lambda s: s.max() - s.min())\nrange_df.columns = [f'{c}_range' for c in range_df.columns]\nagg_flat = agg.copy()\nagg_flat.columns = [f'{a}_{b}' for a, b in agg_flat.columns]\nagg_flat = agg_flat.reset_index().merge(range_df.reset_index(), on=['dataset', 'algorithm'])\n\nprint('\\nAggregate results over seeds:')\nprint(agg.round(4))\nprint('\\nSeed sensitivity ranges:')\nprint(range_df.round(4))\n\nstats_rows = []\nfor dname in datasets:\n    sub = seed_metrics_df[seed_metrics_df['dataset'] == dname]\n    pop = sub[sub['algorithm'] == 'Pop'].sort_values('seed')\n    for algo in ['ALS', 'ItemKNN']:\n        vals = sub[sub['algorithm'] == algo].sort_values('seed')\n        if len(vals) == len(pop) == len(SEEDS):\n            for metric in ['nDCG@10', 'P@10']:\n                x = vals[metric].values\n                y = pop[metric].values\n                stat, pval = ttest_rel(x, y)\n                md, lo, hi = paired_ci(x, y)\n                stats_rows.append({\n                    'dataset': dname,\n                    'comparison': f'{algo} vs Pop',\n                    'metric': metric,\n                    't_stat': float(stat),\n                    'p_value': float(pval),\n                    'mean_diff': float(md),\n                    'ci95_low': float(lo),\n                    'ci95_high': float(hi),\n                })\n                print(f'{dname} | {algo} vs Pop | {metric}: t={stat:.4f}, p={pval:.4f}, diff={md:.4f}, 95% CI=({lo:.4f}, {hi:.4f})')\n\nstats_df = pd.DataFrame(stats_rows)\n\nseed_metrics_df.to_csv(os.path.join(working_dir, 'seed_metrics.csv'), index=False)\nuser_metrics_df.to_csv(os.path.join(working_dir, 'user_metrics.csv'), index=False)\nagg_flat.to_csv(os.path.join(working_dir, 'aggregate_seed_sensitivity.csv'), index=False)\nstats_df.to_csv(os.path.join(working_dir, 'paired_tests.csv'), index=False)\n\nnp.save(os.path.join(working_dir, 'experiment_data.npy'), experiment_data, allow_pickle=True)\nnp.save(os.path.join(working_dir, 'seed_metrics.npy'), seed_metrics_df.to_dict('records'), allow_pickle=True)\nnp.save(os.path.join(working_dir, 'user_metrics.npy'), user_metrics_df.to_dict('records'), allow_pickle=True)\nnp.save(os.path.join(working_dir, 'aggregate_seed_sensitivity.npy'), agg_flat.to_dict('records'), allow_pickle=True)\nnp.save(os.path.join(working_dir, 'paired_tests.npy'), stats_df.to_dict('records'), allow_pickle=True)\n\nprint(f'Artifacts saved to: {working_dir}')\n```", 'Execution Output': '```\nml100k: raw_rows=100000, after_threshold_rows=55375, after_dedup=55375, final_5core_rows=54413, users=938, items=1008, dropped_users_lt2_before_split=0\nTraceback (most recent call last):\n  File "C:\\Users\\Robin\\Documents\\GitHub\\AutoRecLabTeam5\\treesearch\\interpreter.py", line 147, in _run_session\n    exec(compile(code, self.agent_file_name, "exec"), global_scope)\n  File "runfile.py", line 240, in <module>\n    df, summary = loader(path)\n                  ^^^^^^^^^^^^\n  File "runfile.py", line 95, in load_amazon\n    raise ValueError(\'VideoGames.csv must have at least 4 columns: user,item,rating,timestamp\')\nValueError: VideoGames.csv must have at least 4 columns: user,item,rating,timestamp\n