uation step. The script will execute end-to-end at global scope, remain concise, and print the key tables and summaries while writing CSV/NPY/NPZ artifacts for later plotting or reporting.","code":"import os\\nworking_dir = os.path.join(os.getcwd(), \'working\')\\nos.makedirs(working_dir, exist_ok=True)\\n\\nimport warnings, time\\nwarnings.filterwarnings(\'ignore\')\\n\\nimport numpy as np\\nimport pandas as pd\\nfrom scipy.stats import ttest_rel, t\\n\\nfrom lenskit import batch\\nfrom lenskit.algorithms import Recommender\\nfrom lenskit.algorithms.basic import Popular\\nfrom lenskit.algorithms.als import ImplicitMF\\nfrom lenskit.algorithms.item_knn import ItemItem\\n\\nSEEDS = [1, 7, 21, 42, 84]\\nKS = [1, 5, 10]\\nTS = pd.Timestamp.utcnow().isoformat()\\n\\nexperiment_data = {\\n    \'ml100k\': {\'metrics\': {\'train\': [], \'val\': []}, \'losses\': {\'train\': [], \'val\': []}, \'predictions\': [], \'ground_truth\': [], \'preprocess\': []},\\n    \'amazon_videogames\': {\'metrics\': {\'train\': [], \'val\': []}, \'losses\': {\'train\': [], \'val\': []}, \'predictions\': [], \'ground_truth\': [], \'preprocess\': []},\\n    \'lastfm\': {\'metrics\': {\'train\': [], \'val\': []}, \'losses\': {\'train\': [], \'val\': []}, \'predictions\': [], \'ground_truth\': [], \'preprocess\': []},\\n}\\n\\n\\ndef robust_read_csv(path, **kwargs):\\n    kwargs = dict(kwargs)\\n    kwargs.setdefault(\'on_bad_lines\', \'skip\')\\n    return pd.read_csv(path, **kwargs)\\n\\n\\ndef summarize(df, user_col=\'user\', item_col=\'item\'):\\n    return {\'interactions\': int(len(df)), \'users\': int(df[user_col].nunique()), \'items\': int(df[item_col].nunique())}\\n\\n\\ndef k_core_filter(df, user_col=\'user\', item_col=\'item\', min_uc=5, min_ic=5):\\n    df = df[[user_col, item_col]].dropna().drop_duplicates().copy()\\n    changed = True\\n    while changed and len(df):\\n        prev = len(df)\\n        uc = df[user_col].value_counts()\\n        ic = df[item_col].value_counts()\\n        df = df[df[user_col].isin(uc[uc >= min_uc].index) & df[item_col].isin(ic[ic >= min_ic].index)].copy()\\n        changed = len(df) != prev\\n    return df.reset_index(drop=True)\\n\\n\\ndef preprocess_report(name, raw_df, final_df, extra=None):\\n    rep = {\'dataset\': name, \'timestamp\': TS, \'raw\': summarize(raw_df), \'final\': summarize(final_df)}\\n    if extra: rep.update(extra)\\n    experiment_data[name][\'preprocess\'].append(rep)\\n    print(f\\"{name}: raw={rep[\'raw\']} final={rep[\'final\']} extra={extra}\\")\\n\\n\\ndef load_ml100k(path=\'u.data\'):\\n    raw = robust_read_csv(path, sep=\'\\\\t\', header=None, names=[\'user\', \'item\', \'rating\', \'timestamp\'])\\n    raw[\'rating\'] = pd.to_numeric(raw[\'rating\'], errors=\'coerce\')\\n    df = raw.loc[raw[\'rating\'] > 3, [\'user\', \'item\']].dropna()\\n    df[[\'user\', \'item\']] = df[[\'user\', \'item\']].astype(str)\\n    final = k_core_filter(df)\\n    preprocess_report(\'ml100k\', raw[[\'user\', \'item\']].dropna().astype(str), final, {\'implicit_rule\': \'rating>3\'})\\n    return final\\n\\n\\ndef load_amazon(path=\'VideoGames.csv\'):\\n    raw = robust_read_csv(path, header=None, names=[\'user\', \'item\', \'rating\', \'timestamp\'])\\n    raw[\'rating\'] = pd.to_numeric(raw[\'rating\'], errors=\'coerce\')\\n    df = raw.loc[raw[\'rating\'] > 3, [\'user\', \'item\']].dropna()\\n    df[[\'user\', \'item\']] = df[[\'user\', \'item\']].astype(str)\\n    final = k_core_filter(df)\\n    preprocess_report(\'amazon_videogames\', raw[[\'user\', \'item\']].dropna().astype(str), final, {\'implicit_rule\': \'rating>3\'})\\n    return final\\n\\n\\ndef load_lastfm(path=\'UserTaggedArtists-timestamps.dat\'):\\n    raw = robust_read_csv(path, sep=\'\\\\t\')\\n    cols = {c.lower(): c for c in raw.columns}\\n    ucol = cols.get(\'userid\', raw.columns[0])\\n    icol = cols.get(\'artistid\', raw.columns[1])\\n    df = raw[[ucol, icol]].dropna().rename(columns={ucol: \'user\', icol: \'item\'})\\n    df[[\'user\', \'item\']] = df[[\'user\', \'item\']].astype(str)\\n    final = k_core_filter(df)\\n    preprocess_report(\'lastfm\', df, final, {\'implicit_rule\': \'tag event\'})\\n    return final\\n\\n\\ndef drop_low_users(df):\\n    vc = df[\'user\'].value_counts()\\n    keep = vc[vc >= 2].index\\n    out = df[df[\'user\'].isin(keep)].reset_index(drop=True)\\n    return out, int((~df[\'user\'].isin(keep)).sum()), int(df[\'user\'].nunique() - out[\'user\'].nunique())\\n\\n\\ndef user_holdout_split(df, test_ratio=0.2, seed=42):\\n    rng = np.random.default_rng(seed)\\n    train_parts, test_parts = [], []\\n    excluded_users = 0\\n    for _, g in df.groupby(\'user\', sort=False):\\n        n = len(g)\\n        if n < 2:\\n            excluded_users += 1\\n            continue\\n        n_test = max(1, int(np.ceil(n * test_ratio)))\\n        n_test = min(n - 1, n_test)\\n        idx = np.arange(n)\\n        rng.shuffle(idx)\\n        test_idx = idx[:n_test]\\n        mask = np.zeros(n, dtype=bool)\\n        mask[test_idx] = True\\n        train_parts.append(g.iloc[~mask])\\n        test_parts.append(g.iloc[mask])\\n    train = pd.concat(train_parts, ignore_index=True) if train_parts else pd.DataFrame(columns=df.columns)\\n    test = pd.concat(test_parts, ignore_index=True) if test_parts else pd.DataFrame(columns=df.columns)\\n    return train, test, excluded_users\\n\\n\\ndef get_algorithms(seed):\\n    algos = {\\n        \'ALS\': ImplicitMF(features=50, iterations=15, reg=0.1, weight=40, rng_spec=seed),\\n        \'ItemKNN\': ItemItem(20),\\n        \'Pop\': Popular(),\\n    }\\n    return {k: Recommender.adapt(v) for k, v in algos.items()}\\n\\n\\ndef precision_at_k(recs, truth, k):\\n    recs = recs[:k]\\n    return 0.0 if k == 0 else sum(i in truth for i in recs) / k\\n\\n\\ndef ndcg_at_k(recs, truth, k):\\n    recs = recs[:k]\\n    dcg = sum((1 / np.log2(r + 2)) for r, i in enumerate(recs) if i in truth)\\n    m = min(len(truth), k)\\n    if m == 0: return 0.0