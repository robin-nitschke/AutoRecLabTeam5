gorithms.basic import Popular\nfrom lenskit.algorithms.als import ImplicitMF\nfrom lenskit.algorithms.item_knn import ItemItem\nfrom lenskit import batch\n\nSEEDS = [1, 7, 21, 42, 84]\nKS = [1, 5, 10]\n\nexperiment_data = {\n    \'ml100k\': {\'metrics\': {\'train\': [], \'val\': []}, \'losses\': {\'train\': [], \'val\': []}, \'predictions\': [], \'ground_truth\': []},\n    \'amazon_videogames\': {\'metrics\': {\'train\': [], \'val\': []}, \'losses\': {\'train\': [], \'val\': []}, \'predictions\': [], \'ground_truth\': []},\n    \'lastfm\': {\'metrics\': {\'train\': [], \'val\': []}, \'losses\': {\'train\': [], \'val\': []}, \'predictions\': [], \'ground_truth\': []},\n}\n\n\ndef k_core_filter(df, user_col=\'user\', item_col=\'item\', min_uc=5, min_ic=5):\n    df = df[[user_col, item_col]].drop_duplicates().copy()\n    while True:\n        uc = df[user_col].value_counts()\n        ic = df[item_col].value_counts()\n        keep_u = uc[uc >= min_uc].index\n        keep_i = ic[ic >= min_ic].index\n        new_df = df[df[user_col].isin(keep_u) & df[item_col].isin(keep_i)]\n        if len(new_df) == len(df):\n            break\n        df = new_df\n    return df.reset_index(drop=True)\n\n\ndef load_ml100k(path=\'u.data\'):\n    df = pd.read_csv(path, sep=\'\\t\', header=None, names=[\'user\', \'item\', \'rating\', \'timestamp\'])\n    df = df[df[\'rating\'] > 3][[\'user\', \'item\']].copy()\n    return k_core_filter(df)\n\n\ndef load_amazon(path=\'VideoGames.csv\'):\n    cols = [\'user\', \'item\', \'rating\', \'timestamp\']\n    df = pd.read_csv(path, header=None, names=cols)\n    df = df[df[\'rating\'] > 3][[\'user\', \'item\']].copy()\n    return k_core_filter(df)\n\n\ndef load_lastfm(path=\'UserTaggedArtists-timestamps.dat\'):\n    df = pd.read_csv(path, sep=\'\\t\')\n    user_col = \'userID\' if \'userID\' in df.columns else df.columns[0]\n    item_col = \'artistID\' if \'artistID\' in df.columns else df.columns[1]\n    df = df[[user_col, item_col]].rename(columns={user_col: \'user\', item_col: \'item\'})\n    return k_core_filter(df)\n\n\ndef user_holdout_split(df, test_ratio=0.2, seed=42):\n    rng = np.random.default_rng(seed)\n    train_parts, test_parts = [], []\n    for _, g in df.groupby(\'user\', sort=False):\n        n = len(g)\n        n_test = max(1, int(np.ceil(n * test_ratio)))\n        idx = np.arange(n)\n        rng.shuffle(idx)\n        test_idx = idx[:n_test]\n        mask = np.zeros(n, dtype=bool)\n        mask[test_idx] = True\n        test_parts.append(g.iloc[mask])\n        train_parts.append(g.iloc[~mask])\n    train = pd.concat(train_parts, ignore_index=True)\n    test = pd.concat(test_parts, ignore_index=True)\n    return train, test\n\n\ndef get_algorithms():\n    return {\n        \'ALS\': Recommender.adapt(ImplicitMF(features=50, iterations=15, reg=0.01, weight=40)),\n        \'ItemKNN\': Recommender.adapt(ItemItem(30, feedback=\'implicit\')),\n        \'Pop\': Recommender.adapt(Popular()),\n    }\n\n\ndef precision_at_k(recs, truth, k):\n    if len(recs) == 0:\n        return 0.0\n    recs_k = recs[:k]\n    return sum(1 for x in recs_k if x in truth) / k\n\n\ndef ndcg_at_k(recs, truth, k):\n    recs_k = recs[:k]\n    dcg = 0.0\n    for i, item in enumerate(recs_k, start=1):\n        if item in truth:\n            dcg += 1.0 / np.log2(i + 1)\n    ideal_hits = min(len(truth), k)\n    if ideal_hits == 0:\n        return 0.0\n    idcg = sum(1.0 / np.log2(i + 1) for i in range(1, ideal_hits + 1))\n    return dcg / idcg\n\n\ndef evaluate_model(model, train, test, algo_name, dataset_name, seed):\n    model.fit(train)\n    users = test[\'user\'].unique()\n    truth = test.groupby(\'user\')[\'item\'].apply(set).to_dict()\n    recs = batch.recommend(model, users, 10)\n    if recs is None or len(recs) == 0:\n        recs = pd.DataFrame(columns=[\'user\', \'item\', \'rank\', \'score\'])\n    user_recs = recs.groupby(\'user\')[\'item\'].apply(list).to_dict()\n\n    rows = []\n    for u in users:\n        r = user_recs.get(u, [])\n        t = truth.get(u, set())\n        row = {\'dataset\': dataset_name, \'algorithm\': algo_name, \'seed\': seed, \'user\': u}\n        for k in KS:\n            row[f\'P@{k}\'] = precision_at_k(r, t, k)\n            row[f\'nDCG@{k}\'] = ndcg_at_k(r, t, k)\n        rows.append(row)\n    udf = pd.DataFrame(rows)\n    summary = udf[[f\'P@{k}\' for k in KS] + [f\'nDCG@{k}\' for k in KS]].mean().to_dict()\n    print(f\'Seed {seed} | {dataset_name} | {algo_name} | validation_loss = {1 - summary["nDCG@10"]:.4f}\')\n    print({k: round(v, 4) for k, v in summary.items()})\n    experiment_data[dataset_name][\'metrics\'][\'val\'].append({\'seed\': seed, \'algorithm\': algo_name, **summary})\n    experiment_data[dataset_name][\'predictions\'].append(recs[[\'user\', \'item\']].to_dict(\'records\'))\n    experiment_data[dataset_name][\'ground_truth\'].append(test[[\'user\', \'item\']].to_dict(\'records\'))\n    experiment_data[dataset_name][\'losses\'][\'val\'].append({\'seed\': seed, \'algorithm\': algo_name, \'validation_loss\': 1 - summary[\'nDCG@10\']})\n    return udf, recs\n\n\ndef plot_metric_boxplots(results_df, dataset_name):\n    for metric in [\'nDCG@10\', \'P@10\']:\n        pivot = results_df.pivot_table(index=\'seed\', columns=\'algorithm\', values=metric, aggfunc=\'mean\')\n        arrs = [pivot[c].dropna().values for c in pivot.columns]\n        plt.figure(figsize=(6, 4))\n        plt.boxplot(arrs, labels=list(pivot.columns))\n        plt.ylabel(metric)\n        plt.title(f\'{dataset_name}: {metric} over split seeds\')\n        plt.tight_layout()\n        fig_path = os.path.join(working_dir, f\'{dataset_name}_{metric.replace("@", "at")}_boxplot.png\')\n        plt.savefig(fig_path, dpi=150)\n        plt.close()\n        np.save(os.path.join(working_dir, f\'{dataset_name}_{metric.replace("@", "at")}_boxplot_data.npy\'), {c: pivot[c].dropna().values for c in pivot.columns}, allow_pickle=True)\n\n\ndatasets = {\n    \'ml100k\': load_ml100k(\'u.data\'),\n    \'amazon_videogames\': load_amazon(\'VideoGames.csv\'),\n    \'lastfm\': load_lastfm(\'UserTaggedArtists-timestamps.dat\'),\n}\n\nall_user_metrics = []\nall_seed_metrics = []\n\nfor dname, df in datasets.items():\n    print(f\'Loaded {dname}: {len(df):,} interactions, {df.user.nunique():,} users, {df.item.nunique():,} items\')\n    for seed in SEEDS:\n        train, test = user_holdout_split(df, test_ratio=0.2, seed=seed)\n        experiment_data[dname][\'metrics\'][\'train\'].append({\'seed\': seed, \'n_train\': len(train), \'n_test\': len(test)})\n        algos = get_algorithms()\n        for aname, algo in algos.items():\n            udf, recs = evaluate_model(algo, train, test, aname, dname, seed)\n            all_user_metrics.append(udf)\n            seed_summary = udf.drop(columns=[\'user\']).mean(numeric_only=True).to_dict()\n            seed_summary.update({\'dataset\': dname, \'algorithm\': aname, \'seed\': seed})\n            all_seed_metrics.append(seed_summary)\n\nuser_metrics_df = pd.concat(all_user_metrics, ignore_index=True)\nseed_metrics_df = pd.DataFrame(all_seed_metrics)\n\nnp.save(os.path.join(working_dir, \'experiment_data.npy\'), experiment_data, allow_pickle=True)\nnp.savez_compressed(os.path.join(working_dir, \'seed_metrics.npz\'), data=seed_metrics_df.to_records(index=False))\nnp.savez_compressed(os.path.join(working_dir, \'user_metrics.npz\'), data=user_metrics_df.to_records(index=False))\n\nprint(\'\\nAggregate results over seeds (mean ± std):\')\nagg = seed_metrics_df.groupby([\'dataset\', \'algorithm\'])[[f\'P@{k}\' for k in KS] + [f\'nDCG@{k}\' for k in KS]].agg([\'mean\', \'std\'])\nprint(agg.round(4))\n\nprint(\'\\nPaired t-tests on nDCG@10 versus Pop across seeds:\')\nfor dname in datasets:\n    sub = seed_metrics_df[seed_metrics_df[\'dataset\'] == dname]\n    pop = sub[sub[\'algorithm\'] == \'Pop\'].sort_values(\'seed\')[\'nDCG@10\'].values\n    for algo in [\'ALS\', \'ItemKNN\']:\n        vals = sub[sub[\'algorithm\'] == algo].sort_values(\'seed\')[\'nDCG@10\'].values\n        if len(vals) == len(pop) == len(SEEDS):\n            t, p = ttest_rel(vals, pop)\n            print(f\'{dname} | {algo} vs Pop: t={t:.4f}, p={p:.4f}\')\n\nfor dname in datasets:\n    plot_metric_boxplots(seed_metrics_df[seed_metrics_df[\'dataset\'] == dname], dname)\n\nseed_metrics_df.to_csv(os.path.join(working_dir, \'seed_metrics.csv\'), index=False)\nuser_metrics_df.to_csv(os.path.join(working_dir, \'user_metrics.csv\'), index=False)\nprint(f\'Artifacts saved to: {working_dir}\')\n```'}}
