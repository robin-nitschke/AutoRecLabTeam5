def k_core_filter(df, user_col='user', item_col='item', min_uc=5, min_ic=5):
    keep_cols = [c for c in [user_col, item_col, 'rating'] if c in df.columns]
    df = df[keep_cols].dropna().drop_duplicates().copy()
    changed = True
    while changed and len(df):
        n0 = len(df)
