   plt.title(f\'{dataset_name}: {metric} across seeds\')\n        plt.legend()\n        plt.tight_layout()\n        plt.savefig(os.path.join(working_dir, f\'{dataset_name}_{metric.replace("@", "at")}_seed_lines.png\'))\n        plt.close()\n\n    plt.figure(figsize=(8, 4))\n    data = []\n    labels = []\n    for algo in seed_summary[\'algorithm\'].unique():\n        vals = seed_summary[seed_summary[\'algorithm\'] == algo][\'ndcg@10\'].values\n        data.append(vals)\n        labels.append(algo)\n    plt.boxplot(data, labels=labels)\n    plt.ylabel(\'nDCG@10\')\n    plt.title(f\'{dataset_name}: seed sensitivity (nDCG@10)\')\n    plt.tight_layout()\n    plt.savefig(os.path.join(working_dir, f\'{dataset_name}_ndcgat10_seed_boxplot.png\'))\n    plt.close()\n\n    np.save(os.path.join(working_dir, f\'{dataset_name}_seed_summary.npy\'), seed_summary.to_records(index=False))\n    return seed_summary\n\n\ndef statistical_analysis(seed_summary, dataset_name):\n    print(f\'\\n=== {dataset_name} statistical analysis on nDCG@10 ===\')\n    pivot = seed_summary.pivot(index=\'seed\', columns=\'algorithm\', values=\'ndcg@10\')\n    cols = [c for c in [\'Pop\', \'ItemKNN\', \'ALS\'] if c in pivot.columns]\n    groups = [pivot[c].dropna().values for c in cols]\n    if len(groups) >= 2 and all(len(g) > 1 for g in groups):\n        try:\n            fstat, pval = stats.f_oneway(*groups)\n            print(f\'ANOVA F={fstat:.4f}, p={pval:.4g}\')\n        except Exception as e:\n            print(f\'ANOVA failed: {e}\')\n        for i in range(len(cols)):\n            for j in range(i + 1, len(cols)):\n                a, b = cols[i], cols[j]\n                try:\n                    tstat, pval = stats.ttest_rel(pivot[a], pivot[b], nan_policy=\'omit\')\n                    print(f\'paired t-test {a} vs {b}: t={tstat:.4f}, p={pval:.4g}\')\n                except Exception as e:\n                    print(f\'paired t-test {a} vs {b} failed: {e}\')\n    seed_var = seed_summary.groupby(\'algorithm\')[\'ndcg@10\'].agg([\'mean\', \'std\'])\n    print(\'Seed variability (mean/std of nDCG@10):\')\n    print(seed_var)\n\n\ndef build_algorithms():\n    return {\n        \'Pop\': Popular(),\n        \'ItemKNN\': ItemItem(20),\n        \'ALS\': ImplicitMF(50),\n    }\n\n\ndatasets = {\n    \'ml100k\': load_ml100k(\'u.data\'),\n    \'amazon_videogames\': load_amazon(\'VideoGames.csv\'),\n    \'lastfm\': load_lastfm(\'UserTaggedArtists-timestamps.dat\'),\n}\n\nall_results = []\nfor dname, df in datasets.items():\n    print(f\'Loaded {dname}: {len(df)} interactions, {df.user.nunique()} users, {df.item.nunique()} items\')\n    for seed in SEEDS:\n        train, test = user_holdout_split(df, seed=seed, test_ratio=0.2)\n        experiment_data[dname][\'losses\'][\'train\'].append({\'seed\': seed, \'timestamp\': pd.Timestamp.now().isoformat(), \'value\': np.nan})\n        experiment_data[dname][\'losses\'][\'val\'].append({\'seed\': seed, \'timestamp\': pd.Timestamp.now().isoformat(), \'value\': np.nan})\n        print(f\'Epoch {seed}: validation_loss = {np.nan:.4f}\')\n        for aname, algo in build_algorithms().items():\n            res = evaluate_model(algo, train, test, dname, aname, seed, ks=KS)\n            means = res[[f\'precision@{k}\' for k in KS] + [f\'ndcg@{k}\' for k in KS]].mean().to_dict()\n            experiment_data[dname][\'metrics\'][\'val\'].append({\'seed\': seed, \'algorithm\': aname, \'timestamp\': pd.Timestamp.now().isoformat(), **means})\n            all_results.append(res)\n            print(f\'{dname} seed={seed} algo={aname} \' + \' \'.join([f\'P@{k}={means[f"precision@{k}"]:.4f}\' for k in KS]) + \' \' + \' \'.join([f\'nDCG@{k}={means[f"ndcg@{k}"]:.4f}\' for k in KS]))\n\nresults_df = pd.concat(all_results, ignore_index=True)\nresults_df.to_csv(os.path.join(working_dir, \'seed_sensitivity_results.csv\'), index=False)\nnp.save(os.path.join(working_dir, \'all_results.npy\'), results_df.to_records(index=False))\n\nfor dname in datasets:\n    ss = summarize_and_plot(results_df[results_df[\'dataset\'] == dname], dname)\n    statistical_analysis(ss, dname)\n\nnp.save(os.path.join(working_dir, \'experiment_data.npy\'), experiment_data, allow_pickle=True)\nprint(\'\\nSaved outputs to:\', working_dir)\nprint(results_df.groupby([\'dataset\', \'algorithm\', \'seed\'])[[f\'precision@10\', f\'ndcg@10\']].mean())\n```', 'Execution output': '```\nTraceback (most recent call last):\n  File "F:\\Uni\\Semester 6\\ML_Praktikum\\AutoRecLabTeam5\\treesearch\\interpreter.py", line 147, in _run_session\n    exec(compile(code, self.agent_file_name, "exec"), global_scope)\n  File "runfile.py", line 10, in <module>\nModuleNotFoundError: No module named \'matplotlib\'\nExecution time: a second seconds (time limit is an hour).\n```', 'Bug Analysis & Scoring': "\n                Bug Analysis:\n                Execution failed immediately with `ModuleNotFoundError: No module named 'matplotlib'` at the import stage, so none of the data loading, training, evaluation, or statistical analysis ran. As a result, the requested outputs and metrics were not produced. Fix by installing matplotlib in the environment (e.g. `pip install matplotlib`) or by removing/guarding plotting imports and plotting code if figures are optional. After that, rerun the script. It would also be prudent to verify LensKit 0.14.4 and its dependencies are installed before execution.\n\n                This indicates the code failed to execute properly. Focus on addressing the specific error mentioned above.\n                \n                Previous Implementation Scores:\n                - Score: 0.0%\n                - Is Satisfactory: False\n                - Feedback: EXECUTION FAILURE DETECTED:\n\n                    Execution failed immediately with `ModuleNotFoundError: No module named 'matplotlib'` at the import stage, so none of the data loading, training, evaluation, or statistical analysis ran. As a result, the requested outputs and metrics w