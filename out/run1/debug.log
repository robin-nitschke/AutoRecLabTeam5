nimport pandas as pd\\nimport matplotlib.pyplot as plt\\nfrom scipy.stats import f_oneway\\n\\nfrom lenskit import batch, topn\\nfrom lenskit.algorithms.basic import Popular\\nfrom lenskit.algorithms.als import ImplicitMF\\nfrom lenskit.algorithms.item_knn import ItemItem\\n\\nSEEDS = [1, 7, 21, 42, 84]\\nKS = [1, 5, 10]\\n\\nexperiment_data = {\\n    \'ml100k\': {\'metrics\': {\'train\': [], \'val\': []}, \'losses\': {\'train\': [], \'val\': []}, \'predictions\': [], \'ground_truth\': []},\\n    \'amazon_videogames\': {\'metrics\': {\'train\': [], \'val\': []}, \'losses\': {\'train\': [], \'val\': []}, \'predictions\': [], \'ground_truth\': []},\\n    \'lastfm\': {\'metrics\': {\'train\': [], \'val\': []}, \'losses\': {\'train\': [], \'val\': []}, \'predictions\': [], \'ground_truth\': []},\\n}\\n\\n\\ndef k_core_filter(df, user_col=\'user\', item_col=\'item\', min_uc=5, min_ic=5):\\n    df = df[[user_col, item_col]].dropna().drop_duplicates().copy()\\n    changed = True\\n    while changed and len(df):\\n        n0 = len(df)\\n        uc = df[user_col].value_counts()\\n        ic = df[item_col].value_counts()\\n        df = df[df[user_col].isin(uc[uc >= min_uc].index) & df[item_col].isin(ic[ic >= min_ic].index)]\\n        changed = len(df) != n0\\n    return df.reset_index(drop=True)\\n\\n\\ndef load_ml100k(path=\'u.data\'):\\n    df = pd.read_csv(path, sep=\'\\\\t\', header=None, names=[\'user\', \'item\', \'rating\', \'ts\'])\\n    df = df[df[\'rating\'] > 3][[\'user\', \'item\']]\\n    return k_core_filter(df)\\n\\n\\ndef load_amazon(path=\'VideoGames.csv\'):\\n    raw = pd.read_csv(path, header=None)\\n    if raw.shape[1] >= 4:\\n        raw = raw.iloc[:, :4]\\n        raw.columns = [\'user\', \'item\', \'rating\', \'ts\']\\n    elif raw.shape[1] == 3:\\n        raw.columns = [\'user\', \'item\', \'rating\']\\n    else:\\n        raise ValueError(\'Unexpected Amazon VideoGames.csv format\')\\n    df = raw[raw[\'rating\'] > 3][[\'user\', \'item\']]\\n    return k_core_filter(df)\\n\\n\\ndef load_lastfm(path=\'UserTaggedArtists-timestamps.dat\'):\\n    df = pd.read_csv(path, sep=\'\\\\t\')\\n    cols = {c.lower(): c for c in df.columns}\\n    user_col = cols[[c for c in cols if \'user\' in c][0]]\\n    item_candidates = [c for c in cols if \'artist\' in c]\\n    item_col = cols[item_candidates[0]]\\n    df = df[[user_col, item_col]].rename(columns={user_col: \'user\', item_col: \'item\'})\\n    return k_core_filter(df)\\n\\n\\ndef user_holdout(df, seed, test_frac=0.2):\\n    rng = np.random.RandomState(seed)\\n    train_parts, test_parts = [], []\\n    for u, udf in df.groupby(\'user\'):\\n        idx = np.arange(len(udf))\\n        rng.shuffle(idx)\\n        n_test = max(1, int(np.ceil(len(idx) * test_frac)))\\n        test_idx = idx[:n_test]\\n        train_idx = idx[n_test:]\\n        if len(train_idx) == 0:\\n            train_idx = idx[1:]\\n            test_idx = idx[:1]\\n        train_parts.append(udf.iloc[train_idx])\\n        test_parts.append(udf.iloc[test_idx])\\n    train = pd.concat(train_parts, ignore_index=True)\\n    test = pd.concat(test_parts, ignore_index=True)\\n    return train, test\\n\\n\\ndef get_algo(name):\\n    if name == \'ALS\':\\n        return ImplicitMF(features=50, iterations=10, weight=40)\\n    if name == \'ItemKNN\':\\n        return ItemItem(20)\\n    if name == \'Pop\':\\n        return Popular()\\n    raise ValueError(name)\\n\\n\\ndef eval_run(algo, train, test, ks=(1, 5, 10)):\\n    test_users = test[\'user\'].unique()\\n    recs = batch.recommend(algo, test_users, 10)\\n    rla = topn.RecListAnalysis()\\n    for k in ks:\\n        rla.add_metric(topn.precision, k=k)\\n        rla.add_metric(topn.ndcg, k=k)\\n    res = rla.compute(recs, test, train)\\n    out = {}\\n    for k in ks:\\n        pcol = f\'precision@{k}\'\\n        ncol = f\'ndcg@{k}\'\\n        out[pcol] = float(res[pcol].mean()) if pcol in res else np.nan\\n        out[ncol] = float(res[ncol].mean()) if ncol in res e