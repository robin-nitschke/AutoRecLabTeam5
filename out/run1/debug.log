            val_loss = 1.0 - metrics[\'ndcg@10\'] if not np.isnan(metrics[\'ndcg@10\']) else np.nan\n            print(f\'Epoch {seed}: validation_loss = {val_loss:.4f}\')\n            row = {\n                \'timestamp\': now_ts(),\n                \'dataset\': dname,\n                \'seed\': seed,\n                \'algorithm\': aname,\n                **metrics,\n            }\n            all_rows.append(row)\n            experiment_data[dname][\'metrics\'][\'val\'].append(row)\n            experiment_data[dname][\'losses\'][\'val\'].append({\'timestamp\': now_ts(), \'seed\': seed, \'algorithm\': aname, \'validation_loss\': val_loss})\n            experiment_data[dname][\'predictions\'].append({\n                \'timestamp\': now_ts(),\n                \'seed\': seed,\n                \'algorithm\': aname,\n                \'rows\': recs[[\'user\', \'item\', \'rank\']].to_dict(\'records\') if len(recs) else []\n            })\n            gt = test.groupby(\'user\')[\'item\'].apply(list).to_dict()\n            experiment_data[dname][\'ground_truth\'].append({\'timestamp\': now_ts(), \'seed\': seed, \'algorithm\': aname, \'gt\': gt})\n            if len(user_metrics):\n                user_metrics[\'dataset\'] = dname\n                user_metrics[\'seed\'] = seed\n                user_metrics[\'algorithm\'] = aname\n                per_user_rows.append(user_metrics)\n\nresults = pd.DataFrame(all_rows)\nresults.to_csv(os.path.join(working_dir, \'seed_sensitivity_results.csv\'), index=False)\n\nsummary = results.groupby([\'dataset\', \'algorithm\']).agg({m: [\'mean\', \'std\'] for m in [\'precision@1\', \'precision@5\', \'precision@10\', \'ndcg@1\', \'ndcg@5\', \'ndcg@10\']})\nprint(\'\\nMean ± std across seeds:\')\nprint(summary)\n\nstats_rows = []\nfor (dname, aname), g in results.groupby([\'dataset\', \'algorithm\']):\n    for metric in [\'precision@1\', \'precision@5\', \'precision@10\', \'ndcg@1\', \'ndcg@5\', \'ndcg@10\']:\n        vals = g[metric].drop