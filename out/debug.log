rking\')\\nos.makedirs(working_dir, exist_ok=True)\\n\\nimport warnings\\nwarnings.filterwarnings(\'ignore\')\\n\\nimport numpy as np\\nimport pandas as pd\\nimport matplotlib.pyplot as plt\\nfrom scipy.stats import f_oneway\\n\\nfrom lenskit import batch\\nfrom lenskit.algorithms.basic import Popular\\nfrom lenskit.algorithms.als import ImplicitMF\\nfrom lenskit.algorithms.item_knn import ItemItem\\n\\nexperiment_data = {\\n    \'ml100k\': {\'metrics\': {\'train\': [], \'val\': []}, \'losses\': {\'train\': [], \'val\': []}, \'predictions\': [], \'ground_truth\': []},\\n    \'amazon_vg\': {\'metrics\': {\'train\': [], \'val\': []}, \'losses\': {\'train\': [], \'val\': []}, \'predictions\': [], \'ground_truth\': []},\\n    \'lastfm\': {\'metrics\': {\'train\': [], \'val\': []}, \'losses\': {\'train\': [], \'val\': []}, \'predictions\': [], \'ground_truth\': []},\\n}\\n\\nseeds = [1, 7, 21, 42, 84]\\nks = [1, 5, 10]\\n\\n\\ndef load_ml100k(path=\'u.data\'):\\n    df = pd.read_csv(path, sep=\'\\\\t\', names=[\'user\', \'item\', \'rating\', \'timestamp\'])\\n    df = df[df[\'rating\'] > 3][[\'user\', \'item\']].copy()\\n    df[\'rating\'] = 1.0\\n    return df\\n\\n\\ndef load_amazon(path=\'VideoGames.csv\'):\\n    df = pd.read_csv(path, header=None)\\n    if df.shape[1] >= 4:\\n        df = df.iloc[:, :4]\\n        df.columns = [\'user\', \'item\', \'rating\', \'timestamp\']\\n    else:\\n        df.columns = [\'user\', \'item\', \'rating\']\\n    df = df[df[\'rating\'] > 3][[\'user\', \'item\']].copy()\\n    df[\'rating\'] = 1.0\\n    return df\\n\\n\\ndef load_lastfm(path=\'UserTaggedArtists-timestamps.dat\'):\\n    df = pd.read_csv(path, sep=\'\\\\t\')\\n    cols = {c.lower(): c for c in df.columns}\\n    user_col = cols.get(\'userid\', list(df.columns)[0])\\n    item_col = cols.get(\'artistid\', list(df.columns)[1])\\n    df = df[[user_col, item_col]].copy()\\n    df.columns = [\'user\', \'item\']\\n    df[\'rating\'] = 1.0\\n    df = df.drop_duplicates([\'user\', \'item\'])\\n    return df\\n\\n\\ndef core5_filter(df):\\n    df = df[[\'user\', \'item\', \'rating\']].drop_duplicates([\'user\', \'item\']).copy()\\n    while True:\\n        uc = df.groupby(\'user\').size()\\n        ic = df.groupby(\'item\').size()\\n        good_u = uc[uc >= 5].index\\n        good_i = ic[ic >= 5].index\\n        new_df = df[df[\'user\'].isin(good_u) & df[\'item\'].isin(good_i)].copy()\\n        if len(new_df) == len(df):\\n            break\\n        df = new_df\\n    return df.reset_index(drop=True)\\n\\n\\ndef user_holdout_split(df, seed, test_ratio=0.2):\\n    rng = np.random.RandomState(seed)\\n    train_parts, test_parts = [], []\\n    for _, udf in df.groupby(\'user\'):\\n        n = len(udf)\\n        n_test = max(1, int(np.ceil(n * test_ratio)))\\n        idx = np.arange(n)\\n        rng.shuffle(idx)\\n        test_idx = idx[:n_test]\\n        mask = np.zeros(n, dtype=bool)\\n        mask[test_idx] = True\\n        test_parts.append(udf.iloc[mask])\\n        train_parts.append(udf.iloc[~mask])\\n    train = pd.concat(train_parts, ignore_index=True)\\n    test = pd.concat(test_parts, ignore_index=True)\\n    return train, test\\n\\n\\ndef precision_at_k(rec_items, truth, k):\\n    if k == 0:\\n        return 0.0\\n    rec_k = rec_items[:k]\\n    if len(rec_k) == 0:\\n        return 0.0\\n    hits = sum(1 for i in rec_k if i in truth)\\n    return hits / k\\n\\n\\ndef ndcg_at_k(rec_items, truth, k):\\n    rec_k = rec_items[:k]\\n    dcg = 0.0\\n    for idx, item in enumerate(rec_k):\\n        if item in truth:\\n            dcg += 1.0 / np.log2(idx + 2)\\n    ideal_hits = min(len(truth), k)\\n    if ideal_hits == 0:\\n        return 0.0\\n    idcg = sum(1.0 / np.log2(i + 2) for i in range(ideal_hits))\\n    return dcg / idcg if idcg > 0 else 0.0\\n\\n\\ndef evaluate_algo(algo, train, test, ks):\\n    algo.fit(train)\\n    users = test[\'user\'].unique()\\n    cand_n = max(ks)\\n    recs = batch.recommend(algo, users, cand_n)\\n    truth = test.groupby(\'user\')[\'item\'].apply(set).to_dict()\\n    rec_map = recs.groupby(\'user\')[\'item\'].apply(list).to_dict() if len(recs) else {}\\n    rows = []\\n    for u in users:\\n        gt = truth.get(u, set())\\n        ri = rec_map.get(u, [])\\n        row = {\'user\': u}\\n        for k in ks:\\n            row[f\'precision@{k}\'] = precision_at_k(ri, gt, k)\\n            row[f\'ndcg@{k}\'] = ndcg_at_k(ri, gt, k)\\n        rows.append(row)\\n    mdf = pd.DataFrame(rows)\\n    return mdf, rec_map, truth\\n\\n\\ndef make_plots(results_df, dataset_name):\\n    metrics = [\'precision@1\', \'precision@5\', \'precision@10\', \'ndcg@1\', \'ndcg@5\', \'ndcg@10\']\\n    fig, axes = plt.subplots(2, 3, figsize=(12, 7))\\n    axes = axes.ravel()\\n    for ax, metric in zip(axes, metrics):\\n        sub = results_df[results_df[\'dataset\'] == dataset_name]\\n        agg = sub.groupby(\'algorithm\')[metric].agg([\'mean\', \'std\']).reset_index()\\n        ax.bar(agg[\'algorithm\'], agg[\'mean\'], yerr=agg[\'std\'], capsize=4)\\n        ax.set_title(f\'{dataset_name} {metric}\')\\n        ax.tick_params(axis=\'x\', rotation=25)\\n    plt.tight_layout()\\n    fig_path = os.path.join(working_dir, f\'{dataset_name}_seed_sensitivity_metrics.png\')\\n    plt.savefig(fig_path, dpi=150)\\n    plt.close()\\n\\n\\ndatasets = {\\n    \'ml100k\': core5_filter(load_ml100k(\'u.data\')),\\n    \'amazon_vg\': core5_filter(load_amazon(\'VideoGames.csv\')),\\n    \'lastfm\': core5_filter(load_lastfm(\'UserTaggedArtists-timestamps.dat\')),\\n}\\n\\nalgorithms = {\\n    \'Pop\': lambda: Popular(),\\n    \'ItemKNN\': lambda: ItemItem(30),\\n    \'ALS\': lambda: ImplicitMF(50),\\n}\\n\\nall_rows = []\\nfor dname, df in datasets.items():\\n    print(f\'\\\\nDataset {dname}: users={df.user.nunique()}, items={df.item.nunique()}, interactions={len(df)}\')\\n    for seed in seeds:\\n        train, test = user_holdout_split(df, seed=seed, test_ratio=0.2)\\n        val_loss = len(test) / max(len(train) + len(test), 1)\\n        print(f\'Epoch {seed}: validation_loss = {val_loss:.4f}\')\\n        for aname, abuilder in algorithms.items():\\n            algo = abuilder()\\n            metrics_df, rec_map, truth = evaluate_algo(algo, train, test, ks)\\n            means = metrics_df.mean(numeric_only=True).to_dict()\\n            row = {\'dataset\': dname, \'seed\': seed, \'algorithm\': aname}\\n            row.update(means)\\n            all_rows.append(row)\\n            experiment_data[dname][\'metrics\'][\'train\'].append({\'seed\': seed, \'algorithm\': aname, \'value\': float(\'nan\')})\\n            experiment_data[dname][\'metrics\'][\'val\'].append({\'seed\': seed, \'algorithm\': aname, **means})\\n            experiment_data[dname][\'losses\'][\'val\'].append({\'seed\': seed, \'algorithm\': aname, \'validation_loss\': val_loss})\\n            sample_users = list(rec_map.keys())[:20]\\n            experiment_data[dname][\'predictions\'].append({\'seed\': seed, \'algorithm\': aname, \'users\': sample_users, \'items\': [rec_map[u] for u in sample_users]})\\n            experiment_data[dname][\'ground_truth\'].append({\'seed\': seed, \'algorithm\': aname, \'users\': sample_users, \'items\': [list(truth[u]) for u in sample_users]})\\n            print(f\\"{dname} | seed={seed} | {aname} | \\" + \' \'.join([f\'{k}={means[k]:.4f}\' for k in sorted(means)]))\\n\\nresults_df = pd.DataFrame(all_rows)\\nprint(\'\\\\nMean ± std over seeds\')\\nsummary = results_df.groupby([\'dataset\', \'algorithm\']).agg([\'mean\', \'std\'])\\nprint(summary)\\n\\nstats_rows = []\\nfor dname in results_df[\'dataset\'].unique():\\n    for aname in results_df[\'algorithm\'].unique():\\n        sub = results_df[(results_df[\'dataset\'] == dname) & (results_df[\'algorithm\'] == aname)]\\n        for metric in [\'precision@1\', \'precision@5\', \'precision@10\', \'ndcg@1\', \'ndcg@5\', \'ndcg@10\']:\\n            vals = sub[metric].values\\n            cv = float(np.std(vals) / (np.mean(vals) + 1e-12))\\n            stats_rows.append({\'dataset\': dname, \'algorithm\': aname, \'metric\': metric, \'mean\': float(np.mean(vals)), \'std\': float(np.std(vals)), \'cv\': cv})\\n\\nanova_rows = []\\nfor dname in results_df[\'dataset\'].unique():\\n    for metric in [\'precision@1\', \'precision@5\', \'precision@10\', \'ndcg@1\', \'ndcg@5\', \'ndcg@10\']:\\n        groups = [results_df[(results_df[\'dataset\'] == dname) & (results_df[\'algorithm\'] == a)][metric].values for a in results_df[\'algorithm\'].unique()]\\n        if all(len(g) > 1 for g in groups):\\n            f_stat, p_val = f_oneway(*groups)\\n            anova_rows.append({\'dataset\': dname, \'metric\': metric, \'f_stat\': float(f_stat), \'p_value\': float(p_val)})\\n\\nstats_df = pd.DataFrame(stats_rows)\\nanova_df = pd.DataFrame(anova_rows)\\nprint(\'\\\\nSeed sensitivity (per dataset/algorithm/metric):\')\\nprint(stats_df)\\nprint(\'\\\\nANOVA across algorithms within dataset:\')\\nprint(anova_df)\\n\\nfor dname in datasets.keys():\\n    make_plots(results_df, dname)\\n    np.save(os.path.join(working_dir, f\'{dname}_results.npy\'), results_df[results_df[\'dataset\'] == dname].to_dict(\'records\'))\\n\\nnp.save(os.path.join(working_dir, \'experiment_data.npy\'), experiment_data)\\nnp.save(os.path.join(working_dir, \'seed_sensitivity_stats.npy\'), stats_df.to_dict(\'records\'))\\nnp.save(os.path.join(working_dir, \'anova_results.npy\'), anova_df.to_dict(\'records\'))\\n"}', name='return_plan_and_code'), type='function')]))[/cyan]
