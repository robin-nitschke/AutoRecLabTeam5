n(df)}, users={df.user.nunique()}, items={df.item.nunique()}, dropped_users_lt2={dropped_users}")\n    for seed in SEEDS:\n        train, test, excluded = user_holdout_split(df, 0.2, seed)\n        experiment_data[dname][\'metrics\'][\'train\'].append({\'timestamp\': TS, \'seed\': seed, \'n_train\': len(train), \'n_test\': len(test), \'excluded_users\': excluded})\n        algos = get_algorithms(seed)\n        for aname, algo in algos.items():\n            udf = evaluate_model(algo, train, test, aname, dname, seed)\n            all_user_metrics.append(udf)\n            s = udf[[f\'P@{k}\' for k in KS] + [f\'nDCG@{k}\' for k in KS]].mean().to_dict()\n            s.update({\'dataset\': dname, \'algorithm\': aname, \'seed\': seed, \'timestamp\': TS})\n            all_seed_metrics.append(s)\n\nuser_metrics_df = pd.concat(all_user_metrics, ignore_index=True)\nseed_metrics_df = pd.DataFrame(all_seed_metrics)\nprep_df = pd.DataFrame(prep_rows)\n\nmetric_cols = [f\'P@{k}\' for k in KS] + [f\'nDCG@{k}\' for k in KS]\nagg = seed_metrics_df.groupby([\'dataset\', \'algorithm\'])[metric_cols].agg([\'mean\', \'std\', \'min\', \'max\'])\nprint(\'\\nAggregate results over seeds (mean/std/min/max):\')\nprint(agg.round(4))\n\nstats_rows = []\nprint(\'\\nPaired t-tests on nDCG@10 versus Pop across seeds:\')\nfor dname in datasets:\n    sub = seed_metrics_df[seed_metrics_df[\'dataset\'] == dname]\n    pop = sub[sub[\'algorithm\'] == \'Pop\'].sort_values(\'seed\')[\'nDCG@10\'].values\n    for algo in [\'ALS\', \'ItemKNN\']:\n        vals = sub[sub[\'algorithm\'] == algo].sort_values(\'seed\')[\'nDCG@10\'].values\n        if len(vals) == len(pop) == len(SEEDS):\n            stat, pval = ttest_rel(vals, pop)\n            mean_v, sd_v = float(np.mean(vals)), float(np.std(vals, ddof=1))\n            ci = t.ppf(0.975, df=len(vals)-1) * sd_v / np.sqrt(len(vals))\n            print(f\'{dname} | {algo} vs Pop: t={stat:.4f}, p={pval:.4f}, {algo}_mean={mean_v:.4f}±{ci:.4f}\')\n            stats_rows.append({\'dataset\': dname, \'algorithm\': algo, \'baseline\': \'Pop\', \'metric\': \'nDCG@10\', \'t\': stat, \'p\': pval, \'mean\': mean_v, \'ci95_halfwidth\': ci, \'timestamp\': TS})\n\nprep_df.to_csv(os.path.join(working_dir, \'preprocessing_summary.csv\'), index=False)\nuser_metrics_df.to_csv(os.path.join(working_dir, \'user_metrics.csv\'), index=False)\nseed_metrics_df.to_csv(os.path.join(working_dir, \'seed_metrics.csv\'), index=False)\npd.DataFrame(stats_rows).to_csv(os.path.join(working_dir, \'stats_summary.csv\'), index=False)\nnp.save(os.path.join(working_dir, \'experiment_data.npy\'), experiment_data, allow_pickle=True)\nnp.save(os.path.join(working_dir, \'preprocessing_summary.npy\'), prep_df.to_records(index=False), allow_pickle=True)\nnp.save(os.path.join(working_dir, \'user_metrics.npy\'), user_metrics_df.to_records(index=False), allow_pickle=True)\nnp.save(os.path.join(working_dir, \'seed_metrics.npy\'), seed_metrics_df.to_records(index=False), allow_pickle=True)\nnp.save(os.path.join(working_dir, \'stats_summary.npy\'), np.array(stats_rows, dtype=object), allow_pickle=True)\nprint(f\'Artifacts saved to: {working_dir}\')\n```', 'Execution Output': '```\nml100k: raw={\'interactions\': 100000, \'users\': 943, \'items\': 1682} final={\'interactions\': 54413, \'users\': 938, \'items\': 1008} extra={\'implicit_rule\': \'rating>3\'}\namazon_videogames: raw={\'interactions\': 231780, \'users\': 24303, \'items\': 10672} final={\'interactions\': 231780, \'users\': 24303, \'items\': 10672} extra={\'implicit_rule\': \'rating>3\'}\nlastfm: raw={\'interactions\': 186479, \'users\': 1892, \'items\': 12523} final={\'interactions\': 52551, \'users\': 1090, \'items\': 3646} extra={\'implicit_rule\': \'tag event\'}\nml100k: usable after split check -> interactions=54413, users=938, items=1008, dropped_users_lt2=0\nNumba is using threading layer omp - consider TBB\nfound 1 potential runtime problems - see https://boi.st/lkpy-perf\nSeed 1 | ml100k | ALS | validation