ood_users = set(ucnt[ucnt >= 5].index)\n    good_items = set(icnt[icnt >= 5].index)\n    new_imp = imp[imp['user'].isin(good_users) & imp['item'].isin(good_items)].copy()\n    if len(new_imp) == len(imp):\n        break\n    imp = new_imp\n\nall_users = np.sort(imp['user'].unique())\nall_items = np.sort(imp['item'].unique())\n\n\ndef user_holdout_split(data, seed, test_frac=0.2):\n    rng = np.random.RandomState(seed)\n    trains, tests = [], []\n    for u, udf in data.groupby('user'):\n        items = udf['item'].to_numpy().copy()\n        rng.shuffle(items)\n        n = len(items)\n        n_test = max(1, int(np.ceil(n * test_frac)))\n        if n - n_test < 1:\n            n_test = n - 1\n        test_items = items[:n_test]\n        train_items = items[n_test:]\n        trains.append(pd.DataFrame({'user': u, 'item': train_items, 'rating': 1.0}))\n        tests.append(pd.DataFrame({'user': u, 'item': test_items, 'rating': 1.0}))\n    return pd.concat(trains, ignore_index=True), pd.concat(tests, ignore_index=True)\n\n\ndef dcg_at_k(rels, k):\n    rels = np.asarray(rels)[:k]\n    if rels.size == 0:\n        return 0.0\n    denom = np.log2(np.arange(2, rels.size + 2))\n    return float(np.sum(rels / denom))\n\n\ndef evaluate_topk(recs, test_df, k=10):\n    truth = test_df.groupby('user')['item'].apply(set).to_dict()\n    p_scores, ndcg_scores = [], []\n    rec_groups = recs.groupby('user')\n    for u, gt in truth.items():\n        if u in rec_groups.groups:\n            rui = rec_groups.get_group(u).sort_values('rank')\n            items = rui['item'].tolist()[:k]\n        else:\n            items = []\n        hits = [1.0 if i in gt else 0.0 for i in items]\n        p_scores.append(np.sum(hits) / k)\n        ideal_len = min(len(gt), k)\n        idcg = dcg_at_k(np.ones(ideal_len), k)\n        ndcg_scores.append(dcg_at_k(hits, k) / idcg if idcg > 0 else 0.0)\n    return float(np.mean(ndcg_scores)), float(np.mean(p_scores)), truth\n\n\nseeds = [1, 2, 3]\nrows = []\n\nfor seed in seeds:\n    train, test = user_holdout_split(imp, seed=seed, test_frac=0.2)\n    algo = ImplicitMF(features=50, iterations=20, reg=0.1, weight=40)\n    algo.fit(train)\n\n    candidates = pd.DataFrame({'item': all_items})\n    recs = batch.recommend(algo, all_users, 10, candidates=candidates)\n\n    train_items = train.groupby('user')['item'].apply(set).to_dict()\n    if 'item' in recs.columns:\n        recs = recs[~recs.apply(lambda r: r['item'] in train_items.get(r['user'], set()), axis=1)].copy()\n        recs['rank'] = recs.groupby('user')['score'].rank(method='first', ascending=False).astype(int)\n        recs = recs[recs['rank'] <= 10].sort_values(['user', 'rank'])\n\n    ndcg10, p10, truth = evaluate_topk(recs, test, k=10)\n    print(f'Seed {seed}: validation_loss = nan, nDCG@10 = {ndcg10:.4f}, Precision@10 = {p10:.4f}')\n\n    rows.append({'seed': seed, 'nDCG@10': ndcg10, 'Precision@10': p10})\n    experiment_data['ml100k']['metrics']['val'].append({'seed': seed, 'nDCG@10': ndcg10, 'Precision@10': p10})\n    experiment_data['ml100k']['predictions'].append(recs[['user', 'item', 'rank', 'score']].to_dict('records'))\n    experiment_data['ml100k']['ground_truth'].append({int(u): list(items) for u, items in truth.items()})\n    experiment_data['ml100k']['timestamps'].append({'seed': seed})\n\nresults = pd.DataFrame(rows)\nsummary = pd.DataFrame([\n    {'seed': 'mean', 'nDCG@10': results['nDCG@10'].mean(), 'Precision@10': results['Precision@10'].mean()},\n    {'seed': 'std', 'nDCG@10': results['nDCG@10'].std(ddof=1), 'Precision@10': results['Precision@10'].std(ddof=1)}\n])\nout = pd.concat([results, summary], ignore_index=True)\nout_path = os.path.join(working_dir, 'ml100k_implicitmf_results.csv')\nout.to_csv(out_path, index=False)\n\nprint('\\nAggregate results:')\nprint(summary.to_string(index=False))\nprint(f'\\nSaved CSV to: {out_path}')\n\nnp.save(os.path.join(working_dir, 'experiment_data.npy'), experiment_data)\nnp.save(os.path.join(working_dir,