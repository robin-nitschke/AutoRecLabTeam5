redictions\': [], \'ground_truth\': []},\\n}\\n\\nSEEDS = [1, 7, 21, 42, 84]\\nKS = [1, 5, 10]\\nTOPN = max(KS)\\n\\n\\ndef load_ml100k(path=\'u.data\'):\\n    df = pd.read_csv(path, sep=\'\\\\t\', header=None, names=[\'user\', \'item\', \'rating\', \'timestamp\'])\\n    df = df[df[\'rating\'] > 3].copy()\\n    df = df[[\'user\', \'item\']].drop_duplicates()\\n    df[\'rating\'] = 1.0\\n    return df\\n\\n\\ndef load_amazon_vg(path=\'VideoGames.csv\'):\\n    df = pd.read_csv(path)\\n    cols = {c.lower(): c for c in df.columns}\\n    ucol = cols.get(\'userid\', cols.get(\'reviewerid\', cols.get(\'user_id\', list(df.columns)[0])))\\n    icol = cols.get(\'itemid\', cols.get(\'asin\', cols.get(\'item_id\', list(df.columns)[1])))\\n    rcol = cols.get(\'rating\', cols.get(\'overall\', list(df.columns)[2]))\\n    df = df[[ucol, icol, rcol]].copy()\\n    df.columns = [\'user\', \'item\', \'rating\']\\n    df = df[df[\'rating\'] > 3].copy()\\n    df = df[[\'user\', \'item\']].drop_duplicates()\\n    df[\'rating\'] = 1.0\\n    return df\\n\\n\\ndef load_lastfm(path=\'UserTaggedArtists-timestamps.dat\'):\\n    df = pd.read_csv(path, sep=\'\\\\t\')\\n    cols = {c.lower(): c for c in df.columns}\\n    ucol = cols.get(\'userid\', list(df.columns)[0])\\n    icol = cols.get(\'artistid\', list(df.columns)[1])\\n    df = df[[ucol, icol]].copy().drop_duplicates()\\n    df.columns = [\'user\', \'item\']\\n    df[\'rating\'] = 1.0\\n    return df\\n\\n\\ndef k_core_filter(df, k=5):\\n    cur = df[[\'user\', \'item\', \'rating\']].drop_duplicates().copy()\\n    while True:\\n        n0 = len(cur)\\n        ucnt = cur.groupby(\'user\').size()\\n        icnt = cur.groupby(\'item\').size()\\n        cur = cur[cur[\'user\'].isin(ucnt[ucnt >= k].index)]\\n        cur = cur[cur[\'item\'].isin(icnt[icnt >= k].index)]\\n        if len(cur) == n0:\\n            break\\n    return cur.reset_index(drop=True)\\n\\n\\ndef user_holdout_split(df, test_ratio=0.2, seed=42):\\n    rng = np.random.RandomState(seed)\\n    train_parts, test_parts = [], []\\n    for _, udf in df.groupby(\'user\', sort=False):\\n        n = len(udf)\\n        if n < 2:\\n            continue\\n        n_test = max(1, int(np.ceil(n * test_ratio)))\\n        idx = rng.permutation(n)\\n        test_idx = idx[:n_test]\\n        train_idx = idx[n_test:]\\n        if len(train_idx) == 0:\\n            train_idx = idx[1:]\\n            test_idx = idx[:1]\\n        train_parts.append(udf.iloc[train_idx])\\n        test_parts.append(udf.iloc[test_idx])\\n    train = pd.concat(train_parts, ignore_index=True)\\n    test = pd.concat(test_parts, ignore_index=True)\\n    users = np.intersect1d(train[\'user\'].unique(), test[\'user\'].unique())\\n    train = train[train[\'user\'].isin(users)].reset_index(drop=True)\\n    test = test[test[\'user\'].isin(users)].reset_index(drop=True)\\n    return train[[\'user\', \'item\', \'rating\']], test[[\'user\', \'item\', \'rating\']]\\n\\n\\ndef make_recommender(base_algo):\\n    return Recommender.adapt(base_algo)\\n\\n\\ndef evaluate_recs(recs, test, ks=(1, 5, 10)):\\n    truth = test.groupby(\'user\')[\'item\'].apply(set)\\n    recs = recs[[\'user\', \'item\', \'rank\']].copy()\\n    merged = recs.merge(truth.rename(\'truth\').reset_index(), on=\'user\', how=\'inner\')\\n    merged[\'hit\'] = merged.apply(lambda r: 1.0 if r[\'item\'] in r[\'truth\'] else 0.0, axis=1)\\n    rows = []\\n    for user, udf in merged.groupby(\'user\', sort=False):\\n        udf = udf.sort_values(\'rank\')\\n        hits = udf[\'hit\'].to_numpy(dtype=float)\\n        gt = udf[\'truth\'].iloc[0]\\n        out = {\'user\': user}\\n        for k in ks:\\n            hk = hits[:k]\\n            out[f\'precision@{k}\'] = float(hk.sum() / k) if len(hk) else 0.0\\n            if len(hk) == 0 or len(gt) == 0:\\n                out[f\'ndcg@{k}\'] = 0.0\\n            else:\\n                denom = np.log2(np.arange(2, len(hk) + 2))\\n                dcg = float((hk / denom).sum())\\n                idcg_len = min(len(gt), k)\\n                idcg = float((np.ones(idcg_len) / np.log2(np.arange(2, idcg_len + 2))).sum())\\n                out[f\'ndcg@{k}\'] = float(dcg / idcg) if idcg > 0 else 0.0\\n        rows.append(out)\\n    return pd.DataFrame(rows)\\n\\n\\ndef get_algorithms():\\n    return {\\n        \'ALS\': ImplicitMF(features=50, iterations=15, reg=0.1, weight=40),\\n        \'ItemKNN\': ItemItem(30),\\n        \'Pop\': Popular(),\\n    }\\n\\n\\ndatasets = {\\n    \'ml100k\': k_core_filter(load_ml100k(\'u.data\')),\\n    \'amazon_vg\': k_core_filter(load_amazon_vg(\'VideoGames.csv\')),\\n    \'lastfm\': k_core_filter(load_lastfm(\'UserTaggedArtists-timestamps.dat\')),\\n}\\n\\nall_results = []\\n\\nfor dname, df in datasets.items():\\n    print(f\'Loaded {dname}: {len(df):,} interactions, {df.user.nunique():,} users, {df.item.nunique():,} items\')\\n    for seed in SEEDS:\\n        train, test = user_holdout_split(df, test_ratio=0.2, seed=seed)\\n        users = np.intersect1d(train[\'user\'].unique(), test[\'user\'].unique())\\n        for aname, base_algo in get_algorithms().items():\\n            algo = make_recommender(base_algo)\\n            algo.fit(train[[\'user\', \'item\', \'rating\']])\\n            recs = batch.recommend(algo, users, TOPN)\\n            keep_cols = [\'user\', \'item\', \'rank\'] + ([c for c in [\'score\'] if c in recs.columns])\\n            recs = recs[keep_cols].copy()\\n            ures = evaluate_recs(recs, test, KS)\\n            means = ures.drop(columns=[\'user\']).mean().to_dict() if len(ures) else {f\'precision@{k}\': 0.0 for k in KS} | {f\'ndcg@{k}\': 0.0 for k in KS}\\n            row = {\'dataset\': dname, \'algorithm\': aname, \'seed\': seed, **means}\\n            all_results.append(row)\\n            ts = pd.Timestamp.now().isoformat()\\n            experiment_data[dname][\'metrics\'][\'val\'].append({\'timestamp\': ts, \'seed\': seed, \'algorithm\': aname, **means})\\n            experiment_data[dname][\'losses\'][\'val\'].append({\'timestamp\': ts, \'seed\': seed, \'algorithm\': aname, \'validation_loss\': None})\\n            experiment_data[dname][\'predictions\'].append({\'timestamp\': ts, \'seed\': seed, \'algorithm\': aname, \'data\': recs.head(1000).to_dict(\'records\')})\\n            experiment_data[dname][\'ground_truth\'].append({\'timestamp\': ts, \'seed\': seed, \'algorithm\': aname, \'data\': test.head(1000).to_dict(\'records\')})\\n            print(f\'{dname} | {aname} | seed={seed} | validation_loss = N/A | \' + \', \'.join(f\'{k}={v:.4f}\' for k, v in means.items()))\\n\\nresults_df = pd.DataFrame(all_results)\\nresults_path = os.path.join(working_dir, \'seed_sensitivity_results.csv\')\\nresults_df.to_csv(results_path, index=False)\\nnp.save(os.path.join(working_dir, \'experiment_data.npy\'), experiment_data, allow_pickle=True)\\nnp.save(os.path.join(working_dir, \'results_df.npy\'), results_df.to_dict(\'records\'), allow_pickle=True)\\nnp.savez_compressed(os.path.join(working_dir, \'results_table.npz\'), results=results_df.to_records(index=False))\\n\\nmetric_cols = [c for c in results_df.columns if \'@\' in c]\\nstats_rows = []\\nfor (dname, aname), g in results_df.groupby([\'dataset\', \'algorithm\']):\\n    for metric in metric_cols:\\n        vals = g[metric].astype(float).to_numpy()\\n        mean = float(np.mean(vals))\\n        std = float(np.std(vals, ddof=1)) if len(vals) > 1 else 0.0\\n        cv = float(std / mean) if mean != 0 else np.nan\\n        minv = float(np.min(vals))\\n        maxv = float(np.max(vals))\\n        stats_rows.append({\\n            \'dataset\': dname, \'algorithm\': aname, \'metric\': metric,\\n            \'mean\': mean, \'std\': std, \'cv\': cv, \'min\': minv, \'max\': maxv,\\n            \'n_seeds\': len(vals)\\n        })\\n\\npairwise_rows = []\\nfor dname, dg in results_df.groupby(\'dataset\'):\\n    algs = sorted(dg[\'algorithm\'].unique())\\n    for metric in metric_cols:\\n        piv = dg.pivot(index=\'seed\', columns=\'algorithm\', values=metric)\\n        for i in range(len(algs)):\\n            for j in range(i + 1, len(algs)):\\n                a1, a2 = algs[i], algs[j]\\n                sub = piv[[a1, a2]].dropna()\\n                if len(sub) >= 2:\\n                    tstat, pval = stats.ttest_rel(sub[a1], sub[a2])\\n                else:\\n                    tstat, pval = np.nan, np.nan\\n                pairwise_rows.append({\\n                    \'dataset\': dname, \'metric\': metric, \'alg1\': a1, \'alg2\': a2,\\n                    \'mean_alg1\': float(sub[a1].mean()) if len(sub) else np.nan,\\n                    \'mean_alg2\': float(sub[a2].mean()) if len(sub) else np.nan,\\n                    \'mean_diff\': float((sub[a1] - sub[a2]).mean()) if len(sub) else np.nan,\\n                    \'t_stat\': float(tstat) if pd.notna(tstat) else np.nan,\\n                    \'p_value\': float(pval) if pd.notna(pval) else np.nan,\\n                    \'n_pairs\': int(len(sub))\\n                })\\n\\nstats_df = pd.DataFrame(stats_rows)\\npairwise_df = pd.DataFrame(pairwise_rows)\\nstats_df.to_csv(os.path.join(working_dir, \'seed_sensitivity_stats.csv\'), index=False)\\npairwise_df.to_csv(os.path.join(working_dir, \'seed_sensitivity_pairwise_tests.csv\'), index=False)\\nnp.save(os.path.join(working_dir, \'seed_sensitivity_stats.npy\'), stats_df.to_dict(\'records\'), allow_pickle=True)\\nnp.save(os.path.join(working_dir, \'seed_sensitivity_pairwise_tests.npy\'), pairwise_df.to_dict(\'records\'), allow_pickle=True)\\n\\nfor dname in datasets.keys():\\n    dres = results_df[results_df[\'dataset\'] == dname].copy()\\n    for metric in [\'ndcg@10\', \'precision@10\']:\\n        plt.figure(figsize=(8, 4))\\n        labels = [a for a in [\'ALS\', \'ItemKNN\', \'Pop\'] if a in dres[\'algorithm\'].unique()]\\n        plot_df = [dres[dres[\'algorithm\'] == a][metric].values for a in labels]\\n        plt.boxplot(plot_df, labels=labels)\\n        plt.title(f\'{dname} {metric} across split seeds\')\\n        plt.ylabel(metric)\\n        plt.tight_layout()\\n        plt.savefig(os.path.join(working_dir, f\'{dname}_{metric.replace(\\"@\\", \\"at\\")}_boxplot.png\'), dpi=150)\\n        plt.close()\\n\\nprint(\'\\\\nSeed sensitivity summary:\')\\nprint(stats_df.to_string(index=False))\\nprint(\'\\\\nPaired statistical tests across seeds:\')\\nprint(pairwise_df.to_string(index=False))\\nprint(\'\\\\nPer-seed mean results:\')\\nprint(results_df.to_string(index=False))"}', name='return_plan_and_code'), type='function')]))[/cyan]
