, 'item']].drop_duplicates().copy()\n\nwhile True:\n    uc = imp.groupby('user').size()\n    ic = imp.groupby('item').size()\n    good_u = set(uc[uc >= 5].index)\n    good_i = set(ic[ic >= 5].index)\n    nxt = imp[imp['user'].isin(good_u) & imp['item'].isin(good_i)].copy()\n    if len(nxt) == len(imp):\n        break\n    imp = nxt\n\nall_items = set(imp['item'].unique().tolist())\n\ndef user_holdout_split(df, seed, frac=0.2):\n    rng = np.random.RandomState(seed)\n    tr, te = [], []\n    for u, udf in df.groupby('user', sort=True):\n        items = udf['item'].to_numpy().copy()\n        rng.shuffle(items)\n        n_test = max(1, int(np.ceil(len(items) * frac)))\n        if len(items) - n_test < 1:\n            n_test = len(items) - 1\n        te_items, tr_items = items[:n_test], items[n_test:]\n        tr.append(pd.DataFrame({'user': u, 'item': tr_items, 'rating': 1.0}))\n        te.append(pd.DataFrame({'user': u, 'item': te_items, 'rating': 1.0}))\n    return pd.concat(tr, ignore_index=True), pd.concat(te, ignore_index=True)\n\ndef dcg_at_k(rels, k):\n    rels = np.asarray(rels, dtype=float)[:k]\n    return 0.0 if rels.size == 0 else float((rels / np.log2(np.arange(2, rels.size + 2))).sum())\n\ndef evaluate_topk(recs, test_df, users, k=10):\n    truth = test_df.groupby('user')['item'].apply(set).to_dict()\n    rec_map = {u: g.sort_values('rank')['item'].tolist()[:k] for u, g in recs.groupby('user')} if len(recs) else {}\n    eval_users = np.array(sorted(set(users).intersection(rec_map.keys())))\n    ndcgs, precs = [], []\n    for u in eval_users:\n        gt = truth.get(u, set())\n        ranked = rec_map.get(u, [])\n        hits = [1.0 if i in gt else 0.0 for i in ranked]\n        precs.append(sum(hits) / k)\n        idcg = dcg_at_k(np.ones(min(len(gt), k)), k)\n        ndcgs.append(dcg_at_k(hits, k) / idcg if idcg > 0 else 0.0)\n    return float(np.mean(ndcgs)), float(np.mean(precs)), truth, eval_users\n\nseeds = [1, 2, 3]\nrows = []\n\nfor seed in seeds:\n  