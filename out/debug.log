nto mean and standard deviation for both metrics. Save the per-seed values and the aggregate row into a single CSV file in the working directory, and also print the aggregated mean and std values to stdout.", 'Implementation': "```python\nimport os\nworking_dir = os.path.join(os.getcwd(), 'working')\nos.makedirs(working_dir, exist_ok=True)\n\nimport random\nimport numpy as np\nimport pandas as pd\nfrom lenskit.algorithms.als import ImplicitMF\nfrom lenskit import batch\n\nexperiment_data = {\n    'ml100k_implicitmf': {\n        'metrics': {'train': [], 'val': []},\n        'losses': {'train': [], 'val': []},\n        'predictions': [],\n        'ground_truth': [],\n        'timestamps': []\n    }\n}\n\ndef load_interactions(path='u.data'):\n    df = pd.read_csv(path, sep='\\t', header=None, names=['user', 'item', 'rating', 'timestamp'])\n    return df.loc[df['rating'] > 3, ['user', 'item']].drop_duplicates().reset_index(drop=True)\n\ndef iterative_kcore(df, k=5):\n    cur = df[['user', 'item']].copy()\n    while True:\n        uc = cur.groupby('user').size()\n        ic = cur.groupby('item').size()\n        nxt = cur[cur['user'].isin(uc[uc >= k].index) & cur['item'].isin(ic[ic >= k].index)]\n        nxt = nxt.reset_index(drop=True)\n        if len(nxt) == len(cur):\n            return nxt\n        cur = nxt\n\ndef make_holdout(df, seed, frac=0.2):\n    random.seed(seed)\n    np.random.seed(seed)\n    rng = np.random.RandomState(seed)\n    tr_parts, te_parts, skipped = [], [], []\n    for user, udf in df.groupby('user', sort=False):\n        n = len(udf)\n        n_test = int(np.floor(n * frac))\n        if n_test < 1 or (n - n_test) < 1:\n            skipped.append(user)\n            continue\n        order = np.arange(n)\n        rng.shuffle(order)\n        te_idx = order[:n_test]\n        tr_idx = order[n_test:]\n        tr_parts.append(udf.iloc[tr_idx][['user', 'item']])\n        te_parts.append(udf.iloc[te_idx][['user', 'item']])\n    train = pd.concat(tr_parts, ignore_index=True) if tr_parts else pd.DataFrame(columns=['user', 'item'])\n    test = pd.concat(te_parts, ignore_index=True) if te_parts else pd.DataFrame(columns=['user', 'item'])\n    return train, test, skipped\n\ndef dcg_at_k(binary_rels):\n    r = np.asarray(binary_rels, dtype=float)\n    if r.size == 0:\n        return 0.0\n    return float(np.sum(r / np.log2(np.arange(2, r.size + 2))))\n\ndef evaluate(recs, test, users, k=10):\n    truth = test.groupby('user')['item'].apply(set).to_dict()\n    ranked = recs.sort_values(['user', 'rank']).groupby('user')['item'].apply(list).to_dict()\n    ndcgs, precs, preds, gts = [], [], [], []\n    for u in users:\n        rec_items = ranked.get(u, [])[:k]\n        gt = truth.get(u, set())\n        hits = [1 if i in gt else 0 for i in rec_items]\n        precs.append(float(np.mean(hits)) if len(rec_items) else 0.0)\n        ideal = [1] * min(len(gt), k)\n        ndcgs.append(dcg_at_k(hits) / dcg_at_k(ideal) if ideal else 0.0)\n        preds.append((u, rec_items))\n        gts.append((u, sorted(gt)))\n    return float(np.mean(ndcgs)), float(np.mean(precs)), preds, gts\n\ndef batch_recommend_excluding_train(model, train, users, item_universe, n=10):\n    user_train = train.groupby('user')['item'].apply(set).to_dict()\n    universe = pd.Index(item_universe)\n    candidates = {u: universe.difference(pd.Index(list(user_train.get(u, set())))).tolist() for u in users}\n    recs = batch.recommend(model, list(users), n, candidates=candidates)\n    return recs.sort_values(['user', 'rank']).reset_index(drop=True)\n\nall_data = iterative_kcore(load_interactions('u.data'), k=5)\nall_items = all_data['item'].drop_duplicates().tolist()\nseeds = [1, 2, 3]\nrows = []\n\nfor seed in seeds:\n    train, test, skipped = make_holdout(all_data, seed, frac=0.2)\n    eval_users = sorted(set(train['user']).intersection(test['user']))\n    train = train[train['user'].isin(eval_users)].reset_index(drop=True)\n    test = test[test['user'].isin(eval_users)].reset_index(drop=True)\n\n    random.seed(seed)\n    np.random.seed(seed)\n    algo = ImplicitMF(50)\n    algo.fit(train)\n\n    recs = batch_recommend_excluding_train(algo, train, eval_users, all_items, n=10)\n    ndcg, prec, preds, gts = evaluate(recs, test, eval_users, k=10)\n\n    rows.append({\n        'seed': seed,\n        'n_eval_users': len(eval_users),\n        'n_skipped_users': len(skipped),\n        'ndcg@10': ndcg,\n        'precision@10': prec,\n        'ndcg@10_mean': np.nan,\n        'ndcg@10_std': np.nan,\n        'precision@10_mean': np.nan,\n        'precision@10_std': np.nan\n    })\n\n    experiment_data['ml100k_implicitmf']['metrics']['val'].append({'seed': seed, 'ndcg@10': ndcg, 'precision@10': prec})\n    experiment_data['ml100k_implicitmf']['losses']['val'].append({'seed': seed, 'validation_loss': np.nan})\n    experiment_data['ml100k_implicitmf']['predictions'].append(preds)\n    experiment_data['ml100k_implicitmf']['ground_truth'].append(gts)\n    experiment_data['ml100k_implicitmf']['timestamps'].append({'seed': seed, 'evaluated_users': len(eval_users), 'skipped_users': len(skipped)})\n\n    print(f'Epoch {seed}: validation_loss = {np.nan:.4f}')\n    print(f'Seed {seed}: nDCG@10 = {ndcg:.6f}, Precision@10 = {prec:.6f}')\n\nres = pd.DataFrame(rows)\nndcg_mean = float(res['ndcg@10'].mean())\nndcg_std = float(res['ndcg@10'].std(ddof=1))\nprec_mean = float(res['precision@10'].mean())\nprec_std = float(res['precision@10'].std(ddof=1))\n\nagg = pd.DataFrame([{\n    'seed': 'aggregate',\n    'n_eval_users': int(res['n_eval_users'].sum()),\n    'n_skipped_users': int(res['n_skipped_users'].sum()),\n    'ndcg@10': np.nan,\n    'precision@10': np.nan,\n    'ndcg@10_mean': ndcg_mean,\n    'ndcg@10_std': ndcg_std,\n    'precision@10_mean': prec_mean,\n    'precision@10_std': prec_std\n}])\n\nout = pd.concat([res, agg], ignore_index=True)\ncsv_path = os.path.join(os.getcwd(), 'ml100k_lenskit_implicitmf_reproducibility.csv')\nout.to_csv(csv_path, index=False)\n\nprint(f'Aggregated nDCG@10: mean = {ndcg_mean:.6f}, std = {ndcg_std:.6f}')\nprint(f'Aggregated Precision@10: mean = {prec_mean:.6f}, std = {prec_std:.6f}')\n\nnp.save(os.path.join(working_dir, 'experiment_data.npy'), experiment_data, allow_pickle=True)\nnp.save(os.path.join(working_dir, 'ml100k_seed_metrics.npy'), res[['ndcg@10', 'precision@10']].to_numpy())\nnp.save(os.path.join(working_dir, 'ml100k_predictions.npy'), np.array(experiment_data['ml100k_implicitmf']['predictions'], dtype=object), allow_pickle=True)\nnp.save(os.path.join(working_dir, 'ml100k_ground_truth.npy'), np.array(experiment_data['ml100k_implicitmf']['ground_truth'], dtype=object), allow_pickle=True)\nnp.save(os.path.join(working_dir, 'ml100k_timestamps.npy'), np.array(experiment_data['ml100k_implicitmf']['timestamps'], dtype=object), allow_pickle=True)\n\n```", 'Execution Output': '```\nNumba is using threading layer omp - consider TBB\nfound 1 potential runtime problems - see https://boi.st/lkpy-perf\nEpoch 1: validation_loss = nan\nSeed 1: nDCG@10 = 0.197432, Precision@10 = 0.135181\nEpoch 2: validation_loss = nan\nSeed 2: nDCG@10 = 0.197162, Precision@10 = 0.137633\nEpoch 3: validation_loss = nan\nSeed 3: nDCG@10 = 0.211775, Precision@10 = 0.143817\nAggregated nDCG@10: mean = 0.202123, std = 0.008360\nAggregated Precision@10: mean = 0.138877, std = 0.004450\nExecution time: 16 seconds seconds (time limit is an hour).\n```', 'Instructions': ['Carefully analyze the execution output for signs of bugs or failures:', '- Syntax errors, import errors, or runtime exceptions', '- Missing required outputs or metrics', '- Execution timeouts or crashes', '- Incorrect or nonsensical results', '', "If there's a bug, provide a clear summary of the issue and suggest how to fix it.", 'If the execution was successful, leave the summary empty.']}
