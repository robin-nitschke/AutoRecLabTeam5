) & cur[item_col].isin(keep_i)].copy()\\n        if len(new) == len(cur):\\n            return new.reset_index(drop=True)\\n        cur = new\\n\\ndef user_holdout_split(df, seed=42, test_ratio=0.2):\\n    rng = np.random.RandomState(seed)\\n    train_parts, test_parts = [], []\\n    for user, udf in df.groupby(\'user\', sort=False):\\n        udf = udf.sample(frac=1, random_state=rng).reset_index(drop=True)\\n        n = len(udf)\\n        n_test = 0 if n < 2 else max(1, int(np.ceil(n * test_ratio)))\\n        if n_test == 0:\\n            train_parts.append(udf)\\n            continue\\n        test_parts.append(udf.iloc[:n_test])\\n        train_parts.append(udf.iloc[n_test:])\\n    train = pd.concat(train_parts, ignore_index=True)[[\'user\', \'item\']]\\n    test = pd.concat(test_parts, ignore_index=True)[[\'user\', \'item\']] if test_parts else pd.DataFrame(columns=[\'user\', \'item\'])\\n    return train, test\\n\\ndef dcg_at_k(rels, k):\\n    rels = np.asarray(rels)[:k]\\n    if rels.size == 0:\\n        return 0.0\\n    return float(np.sum(rels / np.log2(np.arange(2, rels.size + 2))))\\n\\ndef evaluate_topk(recs, test_df, k=10):\\n    truth = test_df.groupby(\'user\')[\'item\'].apply(set).to_dict()\\n    rows = []\\n    for u, ru in recs.groupby(\'user\', sort=False):\\n        if u not in truth:\\n            continue\\n        ru = ru.sort_values(\'rank\').head(k)\\n        pred = list(ru[\'item\'])\\n        gt = truth[u]\\n        hits = [1 if i in gt else 0 for i in pred]\\n        prec = float(np.sum(hits) / k)\\n        idcg = dcg_at_k([1] * min(len(gt), k), k)\\n        ndcg = 0.0 if idcg == 0 else dcg_at_k(hits, k) / idcg\\n        rows.append((u, prec, ndcg, len(gt)))\\n    return pd.DataFrame(rows, columns=[\'user\', \'precision@10\', \'ndcg@10\', \'n_test\'])\\n\\ndata_path = os.path.join(os.getcwd(), \'u.data\')\\nratings = pd.read_csv(data_path, sep=\'\\\\t\', names=[\'user\', \'item\', \'rating\', \'timestamp\'])\\nimplicit = ratings.loc[ratings[\'rating\'] > 3, [\'user\', \'item\']].drop_duplicates().reset_index(drop=True)\\nimplicit = iterative_k_core(implicit, k=5)\\n\\nseeds = [1, 2, 3]\\nall_results = []\\nper_user_all = []\\n\\nfor seed in seeds:\\n    train, test = user_holdout_split(implicit, seed=seed, test_ratio=0.2)\\n    eval_users = sorted(test[\'user\'].unique())\\n\\n    algo = ImplicitMF(20)\\n    algo.fit(train)\\n\\n    recs = batch.recommend(algo, eval_users, 10)\\n    metrics = evaluate_topk(recs, test, k=10)\\n\\n    p10 = float(metrics[\'precision@10\'].mean()) if len(metrics) else 0.0\\n    ndcg10 = float(metrics[\'ndcg@10\'].mean()) if len(metrics) else 0.0\\n    val_loss = np.nan\\n\\n    print(f\'Seed {seed}: validation_loss = {val_loss}\')\\n    print(f\'Seed {seed}: Precision@10 = {p10:.6f}, nDCG@10 = {ndcg10:.6f}\')\\n\\n    all_results.append({\'seed\': seed, \'precision@10\': p10, \'ndcg@10\': ndcg10, \'n_users\': int(len(metrics))})\\n    if len(metrics):\\n        per_user = metrics[[\'user\', \'precision@10\', \'ndcg@10\']].copy()\\n        per_user[\'seed\'] = seed\\n        per_user_all.append(per_user)\\n\\n    experiment_data[\'ml100k\'][\'metrics\'][\'val\'].append({\'seed\': seed, \'precision@10\': p10, \'ndcg@10\': ndcg10})\\n    experiment_data[\'ml100k\'][\'losses\'][\'val\'].append({\'seed\': seed, \'validation_loss\': val_loss})\\n    experiment_data[\'ml100k\'][\'predictions\'].append(recs[[\'user\', \'item\', \'rank\']].to_dict(\'records\'))\\n    experiment_data[\'ml100k\'][\'ground_truth\'].append(test.groupby(\'user\')[\'item\'].apply(list).to_dict())\\n    experiment_data[\'ml100k\'][\'timestamps\'].append({\'seed\': seed})\\n\\nresults_df = pd.DataFrame(all_results)\\nsummary_df = pd.DataFrame([\\n    {\\n        \'seed\': \'mean\',\\n        \'precision@10\': results_df[\'precision@10\'].mean(),\\n        \'ndcg@10\': results_df[\'ndcg@10\'].mean(),\\n        \'n_users\': results_df[\'n_users\'].mean()\\n    },\\n    {\\n        \'seed\': \'std\',\\n        \'precision@10\': results_df[\'precision@10\'].std(ddof=1),\\n        \'ndcg@10\': results_df[\'ndcg@10\'].std(ddof=1),\\n        \'n_users\': results_df[\'n_users\'].std(ddof=1)\\n    }\\n], columns=[\'seed\', \'precision@10\', \'ndcg@10\', \'n_users\'])\\nfull_csv = pd.concat([results_df, summary_df], ignore_index=True)\\ncsv_path = os.path.join(working_dir, \'implicitmf_ml100k_results.csv\')\\nfull_csv.to_csv(csv_path, index=False)\\n\\nnp.save(os.path.join(working_dir, \'experiment_data.npy\'), experiment_data, allow_pickle=True)\\nnp.save(os.path.join(working_dir, \'ml100k_per_seed_metrics.npy\'), results_df.to_dict(\'records\'), allow_pickle=True)\\nif per_user_all:\\n    per_user_df = pd.concat(per_user_all, ignore_index=True)\\nelse:\\n    per_user_df = pd.DataFrame(columns=[\'user\', \'precision@10\', \'ndcg@10\', \'seed\'])\\nnp.save(os.path.join(working_dir, \'ml100k_per_user_metrics.npy\'), per_user_df.to_dict(\'records\'), allow_pickle=True)\\n\\nprint(\'\\\\nAggregate over seeds:\')\\nprint(f\\"Precision@10 mean={results_df[\'precision@10\'].mean():.6f}, std={results_df[\'precision@10\'].std(ddof=1):.6f}\\")\\nprint(f\\"nDCG@10 mean={results_df[\'ndcg@10\'].mean():.6f}, std={results_df[\'ndcg@10\'].std(ddof=1):.6f}\\")\\nprint(f\'Saved CSV to {csv_path}\')"}', name='return_plan_and_code'), type='function')]))[/cyan]
