, tt, k)\\n        rows.append(row)\\n    udf = pd.DataFrame(rows)\\n    summary = udf[[f\'P@{k}\' for k in KS] + [f\'nDCG@{k}\' for k in KS]].mean().to_dict()\\n    val_loss = 1 - summary[\'nDCG@10\']\\n    print(f\'{dataset_name} | {algo_name} | seed={seed}: validation_loss = {val_loss:.4f}\')\\n    print({k: round(v, 4) for k, v in summary.items()})\\n    experiment_data[dataset_name][\'metrics\'][\'val\'].append({\'seed\': seed, \'algorithm\': algo_name, **summary})\\n    experiment_data[dataset_name][\'losses\'][\'val\'].append({\'seed\': seed, \'algorithm\': algo_name, \'validation_loss\': val_loss})\\n    experiment_data[dataset_name][\'predictions\'].append(recs[[\'user\', \'item\']].to_dict(\'records\'))\\n    experiment_data[dataset_name][\'ground_truth\'].append(test[[\'user\', \'item\']].to_dict(\'records\'))\\n    return udf\\n\\n\\ndef ci95(x):\\n    x = np.asarray(x, dtype=float)\\n    n = len(x)\\n    m = x.mean()\\n    if n < 2:\\n        return (m, m)\\n    se = x.std(ddof=1) / math.sqrt(n)\\n    h = t.ppf(0.975, n - 1) * se\\n    return (m - h, m + h)\\n\\n\\ndatasets = {}\\nfor name, loader, path in [\\n    (\'ml100k\', load_ml100k, \'u.data\'),\\n    (\'amazon_videogames\', load_amazon, \'VideoGames.csv\'),\\n    (\'lastfm\', load_lastfm, \'UserTaggedArtists-timestamps.dat\'),\\n]:\\n    df, summary = loader(path)\\n    datasets[name] = df\\n    experiment_data[name][\'preprocess\'].append(summary)\\n    print(f\'Loaded {name}: {summary}\')\\n\\nall_user_metrics, all_seed_metrics = [], []\\n\\nfor dname, df in datasets.items():\\n    for seed in SEEDS:\\n        train, test, skipped = user_holdout_split(df, 0.2, seed)\\n        experiment_data[dname][\'metrics\'][\'train\'].append({\\n            \'seed\': seed, \'timestamp\': pd.Timestamp.utcnow().isoformat(),\\n            \'n_train\': int(len(train)), \'n_test\': int(len(test)), \'skipped_users\': int(skipped)\\n        })\\n        for aname, algo in get_algorithms(seed).items():\\n            udf = eval_model(algo, train, test, dname, aname, seed)\\n            all_user_metrics.append(udf)\\n            s = udf.drop(columns=[\'user\']).mean(numeric_only=True).to_dict()\\n            s.update({\'dataset\': dname, \'algorithm\': aname, \'seed\': seed})\\n            all_seed_metrics.append(s)\\n\\nuser_metrics_df = pd.concat(all_user_metrics, ignore_index=True)\\nseed_metrics_df = pd.DataFrame(all_seed_metrics)\\n\\nsummary_rows = []\\nfor (d, a), g in seed_metrics_df.groupby([\'dataset\', \'algorithm\']):\\n    row = {\'dataset\': d, \'algorithm\': a}\\n    for m in [f\'P@{k}\' for k in KS] + [f\'nDCG@{k}\' for k in KS]:\\n        vals = g[m].values\\n        row[f\'{m}_mean\'] = vals.mean()\\n        row[f\'{m}_std\'] = vals.std(ddof=1) if len(vals) > 1 else 0.0\\n        row[f\'{m}_min\'] = vals.min()\\n        row[f\'{m}_max\'] = vals.max()\\n        row[f\'{m}_range\'] = vals.max() - vals.min()\\n    summary_rows.append(row)\\nsummary_df = pd.DataFrame(summary_rows)\\n\\nstats_rows = []\\nfor d in datasets:\\n    sub = seed_metrics_df[seed_metrics_df[\'dataset\'] == d]\\n    base = sub[sub[\'algorithm\'] == \'Pop\'].sort_values(\'seed\')\\n    for algo in [\'ALS\', \'ItemKNN\']:\\n        cmp = sub[sub[\'algorithm\'] == algo].sort_values(\'seed\')\\n        for metric in [\'nDCG@10\', \'P@10\']:\\n            x, y = cmp[metric].values, base[metric].values\\n            if len(x) == len(y) == len(SEEDS):\\n                diff = x - y\\n                tt, pv = ttest_rel(x, y)\\n                lo, hi = ci95(diff)\\n                stats_rows.append({\'dataset\': d, \'comparison\': f\'{algo} vs Pop\', \'metric\': metric, \'mean_diff\': diff.mean(), \'ci95_low\': lo, \'ci95_high\': hi, \'t\': tt, \'p\': pv})\\nstats_df = pd.DataFrame(stats_rows)\\n\\nprint(\'\\\\nAggregate over seeds (mean/std/range):\')\\nprint(summary_df.round(4).to_string(index=False))\\nprint(\'\\\\nPaired t-tests across seeds:\')\\nprint(stats_df.round(4).to_string(index=False) 