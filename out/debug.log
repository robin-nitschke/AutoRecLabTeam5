 []}, \'losses\': {\'train\': [], \'val\': []}, \'predictions\': [], \'ground_truth\': []},\\n}\\n\\nSEEDS = [1, 7, 21, 42, 84]\\nKS = [1, 5, 10]\\nMAX_K = max(KS)\\n\\n\\ndef load_ml100k(path=\'u.data\'):\\n    df = pd.read_csv(path, sep=\'\\\\t\', header=None, names=[\'user\', \'item\', \'rating\', \'timestamp\'])\\n    df = df[df[\'rating\'] > 3].copy()\\n    df = df[[\'user\', \'item\']].drop_duplicates().copy()\\n    df[\'rating\'] = 1.0\\n    return df\\n\\n\\ndef load_amazon_vg(path=\'VideoGames.csv\'):\\n    df = pd.read_csv(path)\\n    lcols = {c.lower(): c for c in df.columns}\\n    ucol = lcols.get(\'userid\', lcols.get(\'user_id\', list(df.columns)[0]))\\n    icol = lcols.get(\'asin\', lcols.get(\'itemid\', lcols.get(\'item_id\', list(df.columns)[1])))\\n    rcol = lcols.get(\'overall\', lcols.get(\'rating\', list(df.columns)[2]))\\n    df = df[[ucol, icol, rcol]].copy()\\n    df.columns = [\'user\', \'item\', \'rating\']\\n    df = df[df[\'rating\'] > 3].copy()\\n    df = df[[\'user\', \'item\']].drop_duplicates().copy()\\n    df[\'rating\'] = 1.0\\n    return df\\n\\n\\ndef load_lastfm(path=\'UserTaggedArtists-timestamps.dat\'):\\n    df = pd.read_csv(path, sep=\'\\\\t\')\\n    lcols = {c.lower(): c for c in df.columns}\\n    ucol = lcols.get(\'userid\', list(df.columns)[0])\\n    icol = lcols.get(\'artistid\', list(df.columns)[1])\\n    df = df[[ucol, icol]].copy().drop_duplicates()\\n    df.columns = [\'user\', \'item\']\\n    df[\'rating\'] = 1.0\\n    return df\\n\\n\\ndef k_core_filter(df, k=5):\\n    cur = df[[\'user\', \'item\', \'rating\']].drop_duplicates().copy()\\n    while True:\\n        n0 = len(cur)\\n        uc = cur.groupby(\'user\').size()\\n        cur = cur[cur[\'user\'].isin(uc[uc >= k].index)]\\n        ic = cur.groupby(\'item\').size()\\n        cur = cur[cur[\'item\'].isin(ic[ic >= k].index)]\\n        if len(cur) == n0:\\n            break\\n    cur[\'rating\'] = cur[\'rating\'].astype(float)\\n    return cur.reset_index(drop=True)\\n\\n\\ndef user_holdout_split(df, test_ratio=0.2, seed=42):\\n    rng = np.random.RandomState(seed)\\n    train_parts, test_parts = [], []\\n    for _, udf in df.groupby(\'user\', sort=False):\\n        idx = rng.permutation(len(udf))\\n        udf = udf.iloc[idx].reset_index(drop=True)\\n        n = len(udf)\\n        if n < 2:\\n            continue\\n        n_test = max(1, int(np.ceil(n * test_ratio)))\\n        if n_test >= n:\\n            n_test = 1\\n        test_parts.append(udf.iloc[:n_test])\\n        train_parts.append(udf.iloc[n_test:])\\n    train = pd.concat(train_parts, ignore_index=True)\\n    test = pd.concat(test_parts, ignore_index=True)\\n    users = np.intersect1d(train[\'user\'].unique(), test[\'user\'].unique())\\n    train = train[train[\'user\'].isin(users)].reset_index(drop=True)\\n    test = test[test[\'user\'].isin(users)].reset_index(drop=True)\\n    train[\'rating\'] = train[\'rating\'].astype(float)\\n    test[\'rating\'] = test[\'rating\'].astype(float)\\n    return train[[\'user\', \'item\', \'rating\']], test[[\'user\', \'item\', \'rating\']]\\n\\n\\ndef dcg_at_k(binary_hits, k):\\n    arr = np.asarray(binary_hits, dtype=float)[:k]\\n    if arr.size == 0:\\n        return 0.0\\n    return float((arr / np.log2(np.arange(2, arr.size + 2))).sum())\\n\\n\\ndef evaluate_recs(recs, test, ks=(1, 5, 10)):\\n    truth = test.groupby(\'user\')[\'item\'].apply(set).to_dict()\\n    users = sorted(truth.keys())\\n    if recs.empty:\\n        rows = []\\n        for u in users:\\n            out = {\'user\': u}\\n            for k in ks:\\n                out[f\'precision@{k}\'] = 0.0\\n                out[f\'ndcg@{k}\'] = 0.0\\n            rows.append(out)\\n        return pd.DataFrame(rows)\\n    recs = recs.sort_values([\'user\', \'rank\'])[[\'user\', \'item\', \'rank\']].copy()\\n    rec_groups = {u: g[\'item\'].tolist() for u, g in recs.groupby(\'user\')}\\n    rows = []\\n    for u in users:\\n        gt = truth[u]\\n        items = rec_groups.get(u, [])\\n        hits = [1.0 if i in gt else 0.0 for i in items]\\n        out = {\'user\': u}\\n        for k in ks:\\n            hk = hits[:k]\\n            if len(hk) < k:\\n                hk = hk + [0.0] * (k - len(hk))\\n            out[f\'precision@{k}\'] = float(np.sum(hk) / k)\\n            idcg = dcg_at_k(np.ones(min(len(gt), k)), k)\\n            out[f\'ndcg@{k}\'] = float(dcg_at_k(hk, k) / idcg) if idcg > 0 else 0.0\\n        rows.append(out)\\n    return pd.DataFrame(rows)\\n\\n\\ndef build_recommender(name):\\n    if name == \'ALS\':\\n        algo = ImplicitMF(features=50, iterations=15, reg=0.1, weight=40)\\n    elif name == \'ItemKNN\':\\n        algo = ItemItem(30)\\n    elif name == \'Pop\':\\n        algo = Popular()\\n    else:\\n        raise ValueError(name)\\n    return Recommender.adapt(algo)\\n\\n\\ndef batch_recommend_all(algo, users, n):\\n    try:\\n        recs = batch.recommend(algo, users, n)\\n    except TypeError:\\n        recs = batch.recommend(algo, users=users, n=n)\\n    recs = recs.copy()\\n    if \'rank\' not in recs.columns:\\n        score_col = \'score\' if \'score\' in recs.columns else None\\n        if score_col is not None:\\n            recs = recs.sort_values([\'user\', score_col], ascending=[True, False]).copy()\\n        else:\\n            recs = recs.sort_values([\'user\', \'item\']).copy()\\n        recs[\'rank\'] = recs.groupby(\'user\').cumcount() + 1\\n    return recs\\n\\n\\ndef summarize_seed_variation(results_df):\\n    rows = []\\n    metric_cols = [c for c in results_df.columns if \'@\' in c]\\n    for (dname, aname), g in results_df.groupby([\'dataset\', \'algorithm\']):\\n        vals_by_seed = g.sort_values(\'seed\')\\n        for metric in metric_cols:\\n            vals = vals_by_seed[metric].astype(float).to_numpy()\\n            mean = float(np.mean(vals))\\n            std = float(np.std(vals, ddof=1)) if len(vals) > 1 else 0.0\\n            cv = float(std / mean) if mean != 0 else np.nan\\n            rows.append({\\n                \'dataset\': dname,\\n                \'algorithm\': aname,\\n                \'metric\': metric,\\n                \'mean\': mean,\\n                \'std\': std,\\n                \'cv\': cv,\\n                \'min\': float(np.min(vals)),\\n                \'max\': float(np.max(vals)),\\n                \'range\': float(np.max(vals) - np.min(vals))\\n            })\\n    return pd.DataFrame(rows)\\n\\n\\ndef paired_tests(results_df):\\n    out = []\\n    metric_cols = [c for c in results_df.columns if \'@\' in c]\\n    for dname, ddf in results_df.groupby(\'dataset\'):\\n        algs = sorted(ddf[\'algorithm\'].unique())\\n        for i in range(len(algs)):\\n            for j in range(i + 1, len(algs)):\\n                a1, a2 = algs[i], algs[j]\\n                g1 = ddf[ddf[\'algorithm\'] == a1].sort_values(\'seed\')\\n                g2 = ddf[ddf[\'algorithm\'] == a2].sort_values(\'seed\')\\n                merged = g1[[\'seed\'] + metric_cols].merge(g2[[\'seed\'] + metric_cols], on=\'seed\', suffixes=(f\'_{a1}\', f\'_{a2}\'))\\n                for metric in metric_cols:\\n                    x = merged[f\'{metric}_{a1}\'].to_numpy(dtype=float)\\n                    y = merged[f\'{metric}_{a2}\'].to_numpy(dtype=float)\\n                    if len(x) > 1:\\n                        t, p = stats.ttest_rel(x, y)\\n                    else:\\n                        t, p = np.nan, np.nan\\n                    out.append({\\n                        \'dataset\': dname,\\n                        \'algorithm_1\': a1,\\n                        \'algorithm_2\': a2,\\n                        \'metric\': metric,\\n                        \'mean_diff\': float(np.mean(x - y)),\\n                        \'t_stat\': float(t) if pd.notnull(t) else np.nan,\\n                        \'p_value\': float(p) if pd.notnull(p) else np.nan\\n                    })\\n    return pd.DataFrame(out)\\n\\n\\ndatasets = {\\n    \'ml100k\': k_core_filter(load_ml100k(\'u.data\')),\\n    \'amazon_vg\': k_core_filter(load_amazon_vg(\'VideoGames.csv\')),\\n    \'lastfm\': k_core_filter(load_lastfm(\'UserTaggedArtists-timestamps.dat\')),\\n}\\n\\nall_results = []\\n\\nfor dname, df in datasets.items():\\n    print(f\'Loaded {dname}: {len(df):,} interactions, {df.user.nunique():,} users, {df.item.nunique():,} items\')\\n    for seed in SEEDS:\\n        train, test = user_holdout_split(df, test_ratio=0.2, seed=seed)\\n        users = np.intersect1d(train[\'user\'].unique(), test[\'user\'].unique())\\n        for aname in [\'ALS\', \'ItemKNN\', \'Pop\']:\\n            rec_algo = build_recommender(aname)\\n            rec_algo.fit(train)\\n            recs = batch_recommend_all(rec_algo, users, MAX_K)\\n            keep_cols = [c for c in [\'user\', \'item\', \'rank\', \'score\'] if c in recs.columns]\\n            recs = recs[keep_cols].copy()\\n            ures = evaluate_recs(recs, test, KS)\\n            means = ures.drop(columns=[\'user\']).mean().to_dict()\\n            val_loss = float(1.0 - means[\'ndcg@10\'])\\n            print(f\'Epoch {seed}: validation_loss = {val_loss:.4f}\')\\n            row = {\'dataset\': dname, \'algorithm\': aname, \'seed\': seed, **means}\\n            all_results.append(row)\\n            ts = pd.Timestamp.now().isoformat()\\n            experiment_data[dname][\'metrics\'][\'val\'].append({\'timestamp\': ts, \'seed\': seed, \'algorithm\': aname, **means})\\n            experiment_data[dname][\'losses\'][\'val\'].append({\'timestamp\': ts, \'seed\': seed, \'algorithm\': aname, \'validation_loss\': val_loss})\\n            experiment_data[dname][\'predictions\'].append({\'timestamp\': ts, \'seed\': seed, \'algorithm\': aname, \'rows\': recs.head(1000).to_dict(\'records\')})\\n            experiment_data[dname][\'ground_truth\'].append({\'timestamp\': ts, \'seed\': seed, \'rows\': test.head(1000).to_dict(\'records\')})\\n            print(f\\"{dname} | {aname} | seed={seed} | \\" + \', \'.join([f\'{k}={v:.4f}\' for k, v in means.items()]))\\n\\nresults_df = pd.DataFrame(all_results)\\nresults_path = os.path.join(working_dir, \'seed_sensitivity_results.csv\')\\nresults_df.to_csv(results_path, index=False)\\nnp.save(os.path.join(working_dir, \'experiment_data.npy\'), experiment_data, allow_pickle=True)\\nnp.save(os.path.join(working_dir, \'seed_sensitivity_results.npy\'), results_df.to_dict(\'records\'), allow_pickle=True)\\nnp.savez_compressed(os.path.join(working_dir, \'results_table.npz\'), results=results_df.to_records(index=False))\\n\\nstats_df = summarize_seed_variation(results_df)\\nstats_df.to_csv(os.path.join(working_dir, \'seed_sensitivity_stats.csv\'), index=False)\\nnp.save(os.path.join(working_dir, \'seed_sensitivity_stats.npy\'), stats_df.to_dict(\'records\'), allow_pickle=True)\\n\\npaired_df = paired_tests(results_df)\\npaired_df.to_csv(os.path.join(working_dir, \'seed_sensitivity_paired_tests.csv\'), index=False)\\nnp.save(os.path.join(working_dir, \'seed_sensitivity_paired_tests.npy\'), paired_df.to_dict(\'records\'), allow_pickle=True)\\n\\nfor dname in datasets.keys():\\n    dres = results_df[results_df[\'dataset\'] == dname].copy()\\n    for metric in [\'ndcg@10\', \'precision@10\']:\\n        plt.figure(figsize=(8, 4))\\n        data = [dres[dres[\'algorithm\'] == a][metric].values for a in [\'ALS\', \'ItemKNN\', \'Pop\']]\\n        plt.boxplot(data, labels=[\'ALS\', \'ItemKNN\', \'Pop\'])\\n        plt.title(f\'{dname} {metric} across split seeds\')\\n        plt.ylabel(metric)\\n        plt.tight_layout()\\n        plt.savefig(os.path.join(working_dir, f\'{dname}_{metric.replace(\\"@\\", \\"at\\")}_boxplot.png\'), dpi=150)\\n        plt.close()\\n\\nprint(\'\\\\nSeed sensitivity summary:\')\\nprint(stats_df.to_string(index=False))\\nprint(\'\\\\nPaired t-tests across algorithms using matched seeds:\')\\nprint(paired_df.to_string(index=False))\\nprint(\'\\\\nPer-seed mean results:\')\\nprint(results_df.to_string(index=False))"}', name='return_plan_and_code'), type='function')]))[/cyan]
