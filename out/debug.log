= [\'user\', \'item\']\n    df[\'rating\'] = 1.0\n    return df\n\n\ndef k_core_filter(df, k=5):\n    cur = df[[\'user\', \'item\', \'rating\']].drop_duplicates().copy()\n    while True:\n        n0 = len(cur)\n        ucnt = cur.groupby(\'user\').size()\n        icnt = cur.groupby(\'item\').size()\n        cur = cur[cur[\'user\'].isin(ucnt[ucnt >= k].index)]\n        cur = cur[cur[\'item\'].isin(icnt[icnt >= k].index)]\n        if len(cur) == n0:\n            break\n    return cur.reset_index(drop=True)\n\n\ndef user_holdout_split(df, test_ratio=0.2, seed=42):\n    rng = np.random.RandomState(seed)\n    train_parts, test_parts = [], []\n    for _, udf in df.groupby(\'user\', sort=False):\n        n = len(udf)\n        if n < 2:\n            continue\n        n_test = max(1, int(np.ceil(n * test_ratio)))\n        idx = rng.permutation(n)\n        test_idx = idx[:n_test]\n        train_idx = idx[n_test:]\n        if len(train_idx) == 0:\n            train_idx = idx[1:]\n            test_idx = idx[:1]\n        train_parts.append(udf.iloc[train_idx])\n        test_parts.append(udf.iloc[test_idx])\n    train = pd.concat(train_parts, ignore_index=True)\n    test = pd.concat(test_parts, ignore_index=True)\n    users = np.intersect1d(train[\'user\'].unique(), test[\'user\'].unique())\n    train = train[train[\'user\'].isin(users)].reset_index(drop=True)\n    test = test[test[\'user\'].isin(users)].reset_index(drop=True)\n    return train[[\'user\', \'item\', \'rating\']], test[[\'user\', \'item\', \'rating\']]\n\n\ndef make_recommender(base_algo):\n    return Recommender.adapt(base_algo)\n\n\ndef evaluate_recs(recs, test, ks=(1, 5, 10)):\n    truth = test.groupby(\'user\')[\'item\'].apply(set)\n    recs = recs[[\'user\', \'item\', \'rank\']].copy()\n    merged = recs.merge(truth.rename(\'truth\').reset_index(), on=\'user\', how=\'inner\')\n    merged[\'hit\'] = merged.apply(lambda r: 1.0 if r[\'item\'] in r[\'truth\'] else 0.0, axis=1)\n    rows = []\n    for user, udf in 