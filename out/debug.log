        ucnt = cur[\'user\'].value_counts()\\n        icnt = cur[\'item\'].value_counts()\\n        keep_u = ucnt[ucnt >= min_uc].index\\n        keep_i = icnt[icnt >= min_ic].index\\n        nxt = cur[cur[\'user\'].isin(keep_u) & cur[\'item\'].isin(keep_i)].copy()\\n        if len(nxt) == len(cur):\\n            break\\n        cur = nxt\\n    return cur.reset_index(drop=True)\\n\\n\\ndef filter_min_user_interactions(df, min_n=2):\\n    ucnt = df[\'user\'].value_counts()\\n    keep = ucnt[ucnt >= min_n].index\\n    dropped_users = int((~df[\'user\'].isin(keep)).sum())\\n    return df[df[\'user\'].isin(keep)].reset_index(drop=True), dropped_users\\n\\n\\ndef load_ml100k(path=\'u.data\'):\\n    raw = safe_read_csv(path, sep=\'\\\\t\', header=None, names=[\'user\', \'item\', \'rating\', \'timestamp\'])\\n    raw[\'rating\'] = pd.to_numeric(raw[\'rating\'], errors=\'coerce\')\\n    raw = raw.dropna(subset=[\'user\', \'item\', \'rating\'])\\n    raw = raw[raw[\'rating\'] > 3]\\n    pre = standardize_pairs(raw, \'user\', \'item\')\\n    post = iterative_k_core(pre)\\n    post2, dropped_interactions = filter_min_user_interactions(post, 2)\\n    summary = {\\n        \'raw_rows\': int(len(raw)), \'implicit_pairs_pre_kcore\': int(len(pre)), \'pairs_post_kcore\': int(len(post)),\\n        \'pairs_final\': int(len(post2)), \'users_final\': int(post2.user.nunique()), \'items_final\': int(post2.item.nunique()),\\n        \'dropped_for_lt2_user_interactions\': int(dropped_interactions)\\n    }\\n    return post2, summary\\n\\n\\ndef load_amazon(path=\'VideoGames.csv\'):\\n    raw = safe_read_csv(path, header=None)\\n    if raw.shape[1] < 3:\\n        raise ValueError(\'VideoGames.csv must have at least 3 columns\')\\n    raw = raw.iloc[:, :4].copy()\\n    raw.columns = [\'user\', \'item\', \'rating\', \'timestamp\'][:raw.shape[1]]\\n    raw[\'rating\'] = pd.to_numeric(raw[\'rating\'], errors=\'coerce\')\\n    raw = raw.dropna(subset=[\'user\', \'item\', \'rating\'])\\n    raw = raw[raw[\'rating\'] > 3]\\n    pre = standardize_pairs(raw, \'user\', \'item\')\\n    post = iterative_k_core(pre)\\n    post2, dropped_interactions = filter_min_user_interactions(post, 2)\\n    summary = {\\n        \'raw_rows\': int(len(raw)), \'implicit_pairs_pre_kcore\': int(len(pre)), \'pairs_post_kcore\': int(len(post)),\\n        \'pairs_final\': int(len(post2)), \'users_final\': int(post2.user.nunique()), \'items_final\': int(post2.item.nunique()),\\n        \'dropped_for_lt2_user_interactions\': int(dropped_interactions)\\n    }\\n    return post2, summary\\n\\n\\ndef load_lastfm(path=\'UserTaggedArtists-timestamps.dat\'):\\n    raw = safe_read_csv(path, sep=\'\\\\t\')\\n    cols = {c.lower(): c for c in raw.columns}\\n    ucol = cols[\'userid\'] if \'userid\' in cols else raw.columns[0]\\n    icol = cols[\'artistid\'] if \'artistid\' in cols else raw.columns[1]\\n    raw = raw.dropna(subset=[ucol, icol])\\n    pre = standardize_pairs(raw, ucol, icol)\\n    post = iterative_k_core(pre)\\n    post2, dropped_interactions = filter_min_user_interactions(post, 2)\\n    summary = {\\n        \'raw_rows\': int(len(raw)), \'implicit_pairs_pre_kcore\': int(len(pre)), \'pairs_post_kcore\': int(len(post)),\\n        \'pairs_final\': int(len(post2)), \'users_final\': int(post2.user.nunique()), \'items_final\': int(post2.item.nunique()),\\n        \'dropped_for_lt2_user_interactions\': int(dropped_interactions)\\n    }\\n    return post2, summary\\n\\n\\ndef user_holdout_split(df, test_ratio=0.2, seed=42):\\n    rng = np.random.default_rng(seed)\\n    train_parts, test_parts = [], []\\n    skipped_users = 0\\n    for _, g in df.groupby(\'user\', sort=False):\\n        n = len(g)\\n        if n < 2:\\n            skipped_users += 1\\n            continue\\n        n_test = max(1, int(round(n * test_ratio)))\\n        n_test = min(n - 1, n_test)\\n        idx = np.arange(n)\\n        rng.shuffle(idx)\\n        test_idx = set(idx[:n_test])\\n        mask = np.array([i in t