time import datetime\n\nfrom lenskit.algorithms.als import ImplicitMF\nfrom lenskit.algorithms.item_knn import ItemItem\nfrom lenskit.algorithms.basic import Popular\nfrom lenskit import batch, topn\n\nnp.random.seed(42)\nSEEDS = [11, 29, 47, 83, 101]\nKS = [1, 5, 10]\n\nexperiment_data = {\n    'ml100k': {'metrics': {'train': [], 'val': []}, 'losses': {'train': [], 'val': []}, 'predictions': [], 'ground_truth': []},\n    'amazon_videogames': {'metrics': {'train': [], 'val': []}, 'losses': {'train': [], 'val': []}, 'predictions': [], 'ground_truth': []},\n    'lastfm': {'metrics': {'train': [], 'val': []}, 'losses': {'train': [], 'val': []}, 'predictions': [], 'ground_truth': []},\n}\n\n\ndef k_core_filter(df, user_col='user', item_col='item', min_uc=5, min_ic=5):\n    cur = df[[user_col, item_col]].drop_duplicates().copy()\n    while True:\n        ucnt = cur.groupby(user_col)[item_col].nunique()\n        icnt = cur.groupby(item_col)[user_col].nunique()\n        good_u = set(ucnt[ucnt >= min_uc].index)\n        good_i = set(icnt[icnt >= min_ic].index)\n        new = cur[cur[user_col].isin(good_u) & cur[item_col].isin(good_i)]\n        if len(new) == len(cur):\n            break\n        cur = new\n    return df[df[user_col].isin(cur[user_col].unique()) & df[item_col].isin(cur[item_col].unique())].copy()\n\n\ndef load_ml100k(path='u.data'):\n    df = pd.read_csv(path, sep='\\t', header=None, names=['user', 'item', 'rating', 'timestamp'])\n    df = df[df['rating'] > 3][['user', 'item']].drop_duplicates()\n    df['rating'] = 1.0\n    return k_core_filter(df)\n\n\ndef load_amazon(path='VideoGames.csv'):\n    cols = ['user', 'item', 'rating', 'timestamp']\n    df = pd.read_csv(path, header=None, names=cols)\n    df = df[df['rating'] > 3][['user', 'item']].drop_duplicates()\n    df['rating'] = 1.0\n    return k_core_filter(df)\n\n\ndef load_lastfm(path='UserTaggedArtists-timestamps.dat'):\n    df = pd.read_csv(path, sep='\\t')\n    cols = {c.lower(): c for c in df.columns}\n    user_col = cols[[c for c in cols if 'user' in c][0]]\n    artist_col = cols[[c for c in cols if 'artist' in c][0]]\n    df = df[[user_col, artist_col]].rename(columns={user_col: 'user', artist_col: 'item'}).drop_duplicates()\n    df['rating'] = 1.0\n    return k_core_filter(df)\n\n\ndef user_holdout(df, seed, test_ratio=0.2):\n    rng = np.random.RandomState(seed)\n    train_parts, test_parts = [], []\n    for _, udf in df.groupby('user'):\n        n = len(udf)\n        n_test = max(1, int(np.ceil(n * test_ratio)))\n        idx = np.arange(n)\n        rng.shuffle(idx)\n        test_idx = idx[:n_test]\n        train_idx = idx[n_test:]\n        if len(train_idx) == 0:\n            train_idx = idx[1:]\n            test_idx = idx[:1]\n        train_parts.append(udf.iloc[train_idx])\n        test_parts.append(udf.iloc[test_idx])\n    train = pd.concat(train_parts, ignore_index=True)\n    test = pd.concat(test_parts, ignore_index=True)\n    train_users = set(train['user'].unique())\n    train_items = set(train['item'].unique())\n    test = test[test['user'].isin(train_users) & test['item'].isin(train_items)].copy()\n    return train, test\n\n\ndef make_algo(name):\n    if name == 'ALS':\n        return ImplicitMF(50, iterations=15, weight=40)\n    if name == 'ItemKNN':\n        return ItemItem(20, feedback='implicit')\n    if name == 'Pop':\n        return Popular()\n    raise ValueError(name)\n\n\ndef evaluate_batch(algo, train, test, ks=(1, 5, 10)):\n    users = np.array(sorted(test['user'].unique()))\n    max_k = max(ks)\n    recs = batch.recommend(algo, users, max_k)\n    if recs is None or len(recs) == 0:\n        rows = []\n        for k in ks:\n            rows.append({'k': k, 'precision': 0.0, 'ndcg': 0.0})\n        return pd.DataFrame(rows), pd.DataFrame(columns=['user', 'rank', 'item', 'score'])\n    if 'rank' not in recs.columns:\n        recs = recs.sort_values(['user', 'score'], ascending=[True, False]).copy()\n        recs['rank'] = recs.groupby('user').cumcount() + 1\n    truth = test.groupby('user')['item'].apply(set).to_dict()\n    out = []\n    for k in ks:\n        rk = recs[recs['rank'] <= k]\n        precisions, ndcgs = [], []\n        for u, udf in rk.groupby('user'):\n            pred = list(udf.sort_values('rank')['item'])\n            rel = np.array([1 if i in truth.get(u, set()) else 0 for i in pred], dtype=float)\n            precisions.append(rel.sum() / k)\n            denom = np.sum((2 ** rel - 1) / np.log2(np.arange(2, len(rel) + 2)))\n            ideal_len = min(len(truth.get(u, set())), k)\n            ideal_rel = np.ones(ideal_len)\n            idcg = np.sum((2 ** ideal_rel - 1) / np.log2(np.arange(2, ideal_len + 2))) if ideal_len > 0 else 0.0\n            ndcgs.append(float(denom / idcg) if idcg > 0 else 0.0)\n        missing_users = set(users) - set(rk['user'].unique())\n        if missing_users:\n            precisions.extend([0.0] * len(missing_users))\n            ndcgs.extend([0.0] * len(missing_users))\n        out.append({'k': k, 'precision': float(np.mean(precisions)), 'ndcg': float(np.mean(ndcgs))})\n    return pd.DataFrame(out), recs\n\n\ndatasets = {\n    'ml100k': load_ml100k('u.data'),\n    'amazon_videogames': load_amazon('VideoGames.csv'),\n    'lastfm': load_lastfm('UserTaggedArtists-timestamps.dat'),\n}\n\nall_rows = []\nfor dname, data in datasets.items():\n    print(f'Loaded {dname}: {len(data):,} interactions, {data.user.nunique():,} users, {data.item.nunique():,} items')\n    for seed in SEEDS:\n        train, test = user_holdout(data, seed, 0.2)\n        for aname in ['ALS', 'ItemKNN', 'Pop']:\n            algo = make_algo(aname)\n            algo.fit(train)\n            metrics_df, recs = evaluate_batch(algo, train, test, KS)\n            val_loss = 1.0 - metrics_df.loc[metrics_df['k'] == 10, 'ndcg'].iloc[0]\n            print(f'{dname} | {aname} | seed={seed} | validation_loss = {val_loss:.4f}')\n            ts = datetime.utcnow().isoformat()\n            experiment_data[dname]['losses']['val'].append({'seed': seed, 'algo': aname, 'timestamp': ts, 'validation_loss': float(val_loss)})\n            experiment_data[dname]['predictions'].append({'seed': seed, 'algo': aname, 'n_recs': int(len(recs))})\n            experiment_data[dname]['ground_truth'].append({'seed': seed, 'n_test': int(len(test))})\n            for _, r in metrics_df.iterrows():\n                row = {\n                    'dataset': dname,\n                    'algo': aname,\n                    'seed': seed,\n                    'k': int(r['k']),\n                    'precision': float(r['precision']),\n                    'ndcg': float(r['ndcg']),\n                    'timestamp': ts,\n                }\n                all_rows.append(row)\n                experiment_data[dname]['metrics']['val'].append(row)\n\nresults = pd.DataFrame(all_rows)\nresults.to_csv(os.path.join(working_dir, 'seed_sensitivity_results.csv'), index=False)\nnp.save(os.path.join(working_dir, 'experiment_data.npy'), experiment_data, allow_pickle=True)\nnp.save(os.path.join(working_dir, 'results_array.npy'), results.to_records(index=False))\n\nsummary = results.groupby(['dataset', 'algo', 'k']).agg(\n    precision_mean=('precision', 'mean'),\n    precision_std=('precision', 'std'),\n    ndcg_mean=('ndcg', 'mean'),\n    ndcg_std=('ndcg', 'std')\n).reset_index()\nsummary['precision_cv'] = summary['precision_std'] / summary['precision_mean'].replace(0, np.nan)\nsummary['ndcg_cv'] = summary['ndcg_std'] / summary['ndcg_mean'].replace(0, np.nan)\nprint('\\nAggregate over seeds:')\nprint(summary.round(4).to_string(index=False))\nsummary.to_csv(os.path.join(working_dir, 'summary_stats.csv'), index=False)\nnp.save(os.path.join(working_dir, 'summary_stats.npy'), summary.to_records(index=False))\n\nstats_rows = []\nfor dname in results['dataset'].unique():\n    for k in KS:\n        sub = results[(results['dataset'] == dname) & (results['k'] == k)]\n        pivot_p = sub.pivot(index='seed', columns='algo', values='precision')\n        pivot_n = sub.pivot(index='seed', columns='algo', values='ndcg')\n        algos = list(pivot_p.columns)\n        for i in range(len(algos)):\n            for j in range(i + 1, len(algos)):\n                a1, a2 = algos[i], algos[j]\n                if a1 in pivot_p and a2 in pivot_p:\n                    t_p = stats.ttest_rel(pivot_p[a1], pivot_p[a2], nan_policy='omit')\n                    t_n = stats.ttest_rel(pivot_n[a1], pivot_n[a2], nan_policy='omit')\n                    stats_rows.append({\n                        'dataset': dname, 'k': k, 'algo_1': a1, 'algo_2': a2,\n                        'precision_t': float(t_p.statistic), 'precision_p': float(t_p.pvalue),\n                        'ndcg_t': float(t_n.statistic), 'ndcg_p': float(t_n.pvalue)\n                    })\nstat_df = pd.DataFrame(stats_rows)\nprint('\\nPaired t-tests across seeds:')\nprint(stat_df.round(4).to_string(index=False))\nstat_df.to_csv(os.path.join(working_dir, 'paired_ttests.csv'), index=False)\nnp.save(os.path.join(working_dir, 'paired_ttests.npy'), stat_df.to_records(index=False))\n\nfor dname in results['dataset'].unique():\n    for metric in ['precision', 'ndcg']:\n        fig, axes = plt.subplots(1, len(KS), figsize=(14, 4), sharey=False)\n        for ax, k in zip(axes, KS):\n            sub = results[(results['dataset'] == dname) & (results['k'] == k)]\n            for algo in ['ALS', 'ItemKNN', 'Pop']:\n                ss = sub[sub['algo'] == algo].sort_values('seed')\n                ax.plot(ss['seed'], ss[metric], marker='o', label=algo)\n            ax.set_title(f'{dname} {metric}@{k}')\n            ax.set_xlabel('seed')\n            ax.set_ylabel(metric)\n            ax.grid(True, alpha=0.3)\n        axes[0].legend()\n        plt.tight_layout()\n        fig_path = os.path.join(working_dir, f'{dname}_{metric}_seed_variability.png')\n        plt.savefig(fig_path, dpi=150)\n        plt.close(fig)\n\nprint('\\nDone. Files saved in:', working