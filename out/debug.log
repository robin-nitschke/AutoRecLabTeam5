 & cur[item_col].isin(keep_i)].copy()\n        if len(new) == len(cur):\n            return new.reset_index(drop=True)\n        cur = new\n\ndef user_holdout_split(df, seed=42, test_ratio=0.2):\n    rng = np.random.RandomState(seed)\n    train_parts, test_parts = [], []\n    for user, udf in df.groupby(\'user\'):\n        n = len(udf)\n        n_test = max(1, int(np.ceil(n * test_ratio))) if n >= 2 else 0\n        if n_test == 0:\n            train_parts.append(udf)\n            continue\n        idx = np.arange(n)\n        test_idx = rng.choice(idx, size=n_test, replace=False)\n        mask = np.ones(n, dtype=bool)\n        mask[test_idx] = False\n        train_parts.append(udf.iloc[mask])\n        test_parts.append(udf.iloc[~mask])\n    train = pd.concat(train_parts, ignore_index=True)\n    test = pd.concat(test_parts, ignore_index=True) if test_parts else pd.DataFrame(columns=df.columns)\n    return train, test\n\ndef dcg_at_k(rels, k):\n    rels = np.asarray(rels)[:k]\n    if rels.size == 0:\n        return 0.0\n    denom = np.log2(np.arange(2, rels.size + 2))\n    return float(np.sum(rels / denom))\n\ndef evaluate_topk(recs, test_df, k=10):\n    truth = test_df.groupby(\'user\')[\'item\'].apply(set).to_dict()\n    users = sorted(set(recs[\'user\']).intersection(truth.keys()))\n    rows = []\n    for u in users:\n        ru = recs[recs[\'user\'] == u].sort_values(\'rank\').head(k)\n        pred = list(ru[\'item\'])\n        gt = truth[u]\n        hits = [1 if i in gt else 0 for i in pred]\n        prec = float(np.sum(hits) / k)\n        idcg = dcg_at_k([1] * min(len(gt), k), k)\n        ndcg = 0.0 if idcg == 0 else dcg_at_k(hits, k) / idcg\n        rows.append((u, prec, ndcg, len(gt), pred, list(gt)))\n    res = pd.DataFrame(rows, columns=[\'user\', \'precision\', \'ndcg\', \'n_test\', \'pred\', \'gt\'])\n    return res\n\ndata_path = os.path.join(os.getcwd(), \'u.data\')\nratings = pd.read_csv(data_path, sep=\'\\t\', names=[\'user\', \'item\', \'rating\', \'timestamp\'])\nimplicit = ratings.loc[ratings[\'rating\'] > 3, [\'user\', \'item\']].drop_duplicates().reset_index(drop=True)\nimplicit = iterative_k_core(implicit, k=5)\n\nseeds = [1, 2, 3]\nall_results = []\nper_user_all = []\n\nfor seed in seeds:\n    train, test = user_holdout_split(implicit, seed=seed, test_ratio=0.2)\n    eval_users = sorted(test[\'user\'].unique())\n\n    algo = ImplicitMF()\n    algo.fit(train)\n\n    recs = batch.recommend(algo, eval_users, 10)\n    metrics = evaluate_topk(recs, test, k=10)\n\n    p10 = float(metrics[\'precision\'].mean()) if len(metrics) else 0.0\n    ndcg10 = float(metrics[\'ndcg\'].mean()) if len(metrics) else 0.0\n\n    print(f\'Seed {seed}: validation_loss = nan\')\n    print(f\'Seed {seed}: Precision@10 = {p10:.6f}, nDCG@10 = {ndcg10:.6f}\')\n\n    all_results.append({\'seed\': seed, \'precision@10\': p10, \'ndcg@10\': ndcg10, \'n_users\': len(metrics)})\n    per_user = metrics[[\'user\', \'precision\', \'ndcg\']].copy()\n    per_user[\'seed\'] = seed\n    per_user_all.append(per_user)\n\n    experiment_data[\'ml100k\'][\'metrics\'][\'val\'].append({\'seed\': seed, \'precision@10\': p10, \'ndcg@10\': ndcg10})\n    experiment_data[\'ml100k\'][\'losses\'][\'val\'].append({\'seed\': seed, \'validation_loss\': np.nan})\n    experiment_data[\'ml100k\'][\'predictions\'].append(recs[[\'user\', \'item\', \'rank\']].to_dict(\'records\'))\n    experiment_data[\'ml100k\'][\'ground_truth\'].append(test.groupby(\'user\')[\'item\'].apply(list).to_dict())\n    experiment_data[\'ml100k\'][\'timestamps\'].append({\'seed\': seed})\n\nresults_df = pd.DataFrame(all_results)\nsummary_df = pd.DataFrame([\n    {\n        \'seed\': \'mean\',\n        \'precision@10\': results_df[\'precision@10\'].mean(),\n        \'ndcg@10\': results_df[\'ndcg@10\'].mean(),\n        \'n_users\': results_df[\'n_users\'].mean()\n    },\n    {\n        \'seed\': \'std\',\n        \'precision@10\': results_df[\'precision@10\'].std(ddof=1),\n        \'ndcg@10\': res