 statistical analysis (paired t-tests on seed-wise metric vectors):\')\\nfor ds_name in datasets.keys():\\n    for metric in [\'precision@1\', \'precision@5\', \'precision@10\', \'ndcg@1\', \'ndcg@5\', \'ndcg@10\']:\\n        a = np.array(all_results[ds_name][\'ALS\'][metric], dtype=float)\\n        b = np.array(all_results[ds_name][\'ItemKNN\'][metric], dtype=float)\\n        c = np.array(all_results[ds_name][\'Pop\'][metric], dtype=float)\\n        print(f\'{ds_name} {metric}:\')\\n        for pair_name, x, y in [(\'ALS-ItemKNN\', a, b), (\'ALS-Pop\', a, c), (\'ItemKNN-Pop\', b, c)]:\\n            valid = ~np.isnan(x) & ~np.isnan(y)\\n            if valid.sum() >= 2:\\n                t = stats.ttest_rel(x[valid], y[valid])\\n                print(f\'  {pair_name} p={t.pvalue:.4f}\')\\n            else:\\n                print(f\'  {pair_name} p=nan\')\\n\\n# Save experiment data and summary arrays\\nfor ds_name in datasets.keys():\\n    experiment_data[ds_name].setdefault(\'aggregates\', {})\\n    for algo in all_results[ds_name]:\\n        experiment_data[ds_name][\'aggregates\'].setdefault(algo, {})\\n        for metric, arr in all_results[ds_name][algo].items():\\n            experiment_data[ds_name][\'aggregates\'][algo][metric] = np.array(arr, dtype=float)\\n\\nnp.save(os.path.join(working_dir, \'experiment_data.npy\'), experiment_data, allow_pickle=True)\\nnp.save(os.path.join(working_dir, \'summary_table.npy\'), summary_df.to_numpy(), allow_pickle=True)\\n\\n# Plot metrics per dataset\\nmetrics_to_plot = [\'precision@1\', \'precision@5\', \'precision@10\', \'ndcg@1\', \'ndcg@5\', \'ndcg@10\']\\nfor ds_name in datasets.keys():\\n    fig, axes = plt.subplots(2, 3, figsize=(14, 8))\\n    axes = axes.ravel()\\n    for idx, metric in enumerate(metrics_to_plot):\\n        vals = [np.nanmean(all_results[ds_name][algo][metric]) for algo in [\'ALS\', \'ItemKNN\', \'Pop\']]\\n        stds = [np.nanstd(all_results[ds_name][algo][metric], ddof=1) for algo in [\'ALS\',