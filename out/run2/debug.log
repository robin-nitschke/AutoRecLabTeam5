ort batch, topn\nfrom lenskit.algorithms.basic import Popular\nfrom lenskit.algorithms.item_knn import ItemItem\nfrom lenskit.algorithms.als import ImplicitMF\nfrom lenskit import crossfold as xf\n\n# -------------------------\n# Data loading / preprocessing\n# -------------------------\n\ndef load_movielens(path=\'u.data\'):\n    df = pd.read_csv(path, sep=\'\\t\', names=[\'user\', \'item\', \'rating\', \'timestamp\'])\n    df = df[df[\'rating\'] > 3].copy()\n    df = df[[\'user\', \'item\']].drop_duplicates()\n    return df\n\n\ndef load_amazon(path=\'VideoGames.csv\'):\n    df = pd.read_csv(path)\n    cols = {c.lower(): c for c in df.columns}\n    user_col = cols.get(\'reviewerid\', cols.get(\'user_id\', list(df.columns)[0]))\n    item_col = cols.get(\'asin\', cols.get(\'item_id\', list(df.columns)[1]))\n    rating_col = cols.get(\'overall\', cols.get(\'rating\', None))\n    if rating_col is None:\n        raise ValueError(\'Could not identify rating column in Amazon dataset.\')\n    df = df[[user_col, item_col, rating_col]].copy()\n    df = df[df[rating_col] > 3].copy()\n    df.columns = [\'user\', \'item\', \'rating\']\n    return df[[\'user\', \'item\']].drop_duplicates()\n\n\ndef load_lastfm(path=\'UserTaggedArtists-timestamps.dat\'):\n    df = pd.read_csv(path, sep=\'\\t\', header=None, names=[\'user\', \'item\', \'tag\', \'timestamp\'], engine=\'python\')\n    return df[[\'user\', \'item\']].drop_duplicates()\n\n\ndef core_filter(df, min_core=5):\n    df = df[[\'user\', \'item\']].drop_duplicates().copy()\n    changed = True\n    while changed:\n        changed = False\n        uc = df[\'user\'].value_counts()\n        ic = df[\'item\'].value_counts()\n        keep_users = uc[uc >= min_core].index\n        keep_items = ic[ic >= min_core].index\n        new_df = df[df[\'user\'].isin(keep_users) & df[\'item\'].isin(keep_items)].copy()\n        if len(new_df) != len(df):\n            changed = True\n            df = new_df\n    return df.reset_index(drop=True)\n\n\n# -------------------------\n# Splitting / evaluation\n# -------------------------\n\ndef make_seed_split(df, seed):\n    rng = np.random.RandomState(seed)\n    train_rows = []\n    test_rows = []\n    for u, g in df.groupby(\'user\'):\n        idx = g.index.to_numpy()\n        n_test = max(1, int(np.floor(0.2 * len(idx))))\n        test_idx = rng.choice(idx, size=n_test, replace=False)\n        train_idx = np.setdiff1d(idx, test_idx, assume_unique=False)\n        if len(train_idx) == 0:\n            train_idx = test_idx[:1]\n            test_idx = test_idx[1:]\n        train_rows.append(df.loc[train_idx])\n        if len(test_idx) > 0:\n            test_rows.append(df.loc[test_idx])\n    train = pd.concat(train_rows, ignore_index=True)\n    test = pd.concat(test_rows, ignore_index=True) if test_rows else df.iloc[0:0].copy()\n    return train[[\'user\', \'item\']].drop_duplicates(), test[[\'user\', \'item\']].drop_duplicates()\n\n\ndef precision_ndcg_at_k(recs, test, k_list=(1, 5, 10)):\n    truth = test.groupby(\'user\')[\'item\'].apply(set).to_dict()\n    recs = recs[[\'user\', \'item\', \'rank\']].copy()\n    recs[\'rank\'] = recs[\'rank\'].astype(int)\n    out = {}\n    for k in k_list:\n        p_vals, ndcg_vals = [], []\n        for u, gt in truth.items():\n            ur = recs[recs[\'user\'] == u].sort_values(\'rank\').head(k)[\'item\'].tolist()\n            if not gt:\n                continue\n            hits = [1 if i in gt else 0 for i in ur]\n            p_vals.append(sum(hits) / k)\n            dcg = sum(rel / np.log2(i + 2) for i, rel in enumerate(hits))\n            idcg = sum(1 / np.log2(i + 2) for i in range(min(len(gt), k)))\n            ndcg_vals.append(dcg / idcg if idcg > 0 else 0.0)\n        out[f\'precision@{k}\'] = float(np.mean(p_vals)) if p_vals else np.nan\n        out[f\'ndcg@{k}\'] = float(np.mean(ndcg_vals)) if ndcg_vals else np.nan\n    return out\n\n\ndef train_and_eval(train, test, seed):\n    algos = {\n        \'ALS\': ImplicitMF(features=20, iterations=15, reg=0.1, rng_spec=seed),\n        \'ItemKNN\': ItemItem(nnbrs=50, min_nbrs=1, min_sim=0.0, center=False),\n        \'Pop\': Popular()\n    }\n    results = {}\n    users = test[\'user\'].unique()\n    for name, algo in algos.items():\n        algo.fit(train)\n        recs = batch.recommend(algo, users, 10, ratings=train)\n        results[name] = precision_ndcg_at_k(recs, test)\n    return results\n\n\ndef summarize_results(all_results):\n    rows = []\n    for ds, algos in all_results.items():\n        for algo, mets in algos.items():\n            for metric, arr in mets.items():\n                arr = np.asarray(arr, dtype=float)\n                rows.append({\n                    \'dataset\': ds,\n                    \'algo\': algo,\n                    \'metric\': metric,\n                    \'mean\': float(np.nanmean(arr)),\n                    \'std\': float(np.nanstd(arr, ddof=1)) if len(arr) > 1 else 0.0,\n                })\n    return pd.DataFrame(rows)\n\n\n# -------------------------\n# Experiment setup\n# -------------------------\n\nexperiment_data = {\n    \'MovieLens100K\': {\'metrics\': {\'train\': [], \'val\': []}, \'losses\': {\'train\': [], \'val\': []}, \'predictions\': [], \'ground_truth\': [], \'details\': [], \'aggregates\': {}},\n    \'AmazonVideoGames\': {\'metrics\': {\'train\': [], \'val\': []}, \'losses\': {\'train\': [], \'val\': []}, \'predictions\': [], \'ground_truth\': [], \'details\': [], \'aggregates\': {}},\n    \'LastFM\': {\'metrics\': {\'train\': [], \'val\': []}, \'losses\': {\'train\': [], \'val\': []}, \'predictions\': [], \'ground_truth\': [], \'details\': [], \'aggregates\': {}},\n}\n\nnp.random.seed(42)\nseeds = [11, 22, 33, 44, 55]\n\ndatasets = {\n    \'MovieLens100K\': load_movielens(\'u.data\'),\n    \'AmazonVideoGames\': load_amazon(\'VideoGames.csv\'),\n    \'LastFM\': load_lastfm(\'UserTaggedArtists-timestamps.dat\'),\n}\n\nfor ds_name, df in list(datasets.items()):\n    df = core_filter(df, min_core=5)\n    datasets[ds_name] = df\n    print(f\'{ds_name}: {len(df)} interactions, {df.user.nunique()} users, {df.item.nunique()} items\')\n\nall_results = defaultdict(lambda: defaultdict(lambda: defaultdict(list)))\n\nfor ds_name, df in datasets.items():\n    for seed in seeds:\n        train, test = make_seed_split(df, seed)\n        split_res = train_and_eval(train, test, seed)\n        for algo, met in split_res.items():\n            for metric, val in met.items():\n                all_results[ds_name][algo][metric].append(val)\n                experiment_data[ds_name][\'metrics\'][\'val\'].append({\'seed\': seed, \'algo\': algo, \'metric\': metric, \'value\': val})\n        experiment_data[ds_name][\'details\'].append({\'seed\': seed, \'n_train\': len(train), \'n_test\': len(test)})\n        print(f\'Completed {ds_name} seed={seed}\')\n\nsummary_df = summarize_results(all_results)\nprint(\'\\nSummary (mean ± std across seeds):\')\nprint(summary_df.sort_values([\'dataset\', \'algo\', \'metric\']).to_string(index=False))\n\nprint(\'\\nShort statistical analysis (paired t-tests on seed-wise metric vectors):\')\nfor ds_name in datasets.keys():\n    for metric in [\'precision@1\', \'precision@5\', \'precision@10\', \'ndcg@1\', \'ndcg@5\', \'ndcg@10\']:\n        a = np.array(all_results[ds_name][\'ALS\'][metric], dtype=float)\n        b = np.array(all_results[ds_name][\'ItemKNN\'][metric], dtype=float)\n        c = np.array(all_results[ds_name][\'Pop\'][metric], dtype=float)\n        print(f\'{ds_name} {metric}: ALS-ItemKNN p={stats.ttest_rel(a, b, nan_policy="omit").pvalue:.4f}, \'\n              f\'ALS-Pop p={stats.ttest_rel(a, c, nan_policy="omit").pvalue:.4f}, \'\n              f\'ItemKNN-Pop p={stats.ttest_rel(b, c, nan_policy="omit").pvalue:.4f}\')\n\nfor ds_name in datasets.keys():\n    for algo in all_results[ds_name]:\n        experiment_data[ds_name][\'aggregates\'][algo] = {}\n        for metric, arr in all_results[ds_name][algo].items():\n            experiment_data[ds_name][\'aggregates\'][algo][metric] = np.asarray(arr, dtype=float)\n\nnp.save(os.path.join(working_dir, \'experiment_data.npy\'), experiment_data, allow_pickle=True)\nnp.save(os.path.join(working_dir, \'summary_table.npy\'), summary_df.to_numpy(), allow_pickle=True)\n\nmetrics_to_plot = [\'precision@1\', \'precision@5\', \'precision@10\', \'ndcg@1\', \'ndcg@5\', \'ndcg@10\']\nfor ds_name in datasets.keys():\n    fig, axes = plt.subplots(2, 3, figsize=(14, 8))\n    axes = axes.ravel()\n    for idx, metric in enumerate(metrics_to_plot):\n        vals = [np.mean(all_results[ds_name][algo][metric]) for algo in [\'ALS\', \'ItemKNN\', \'Pop\']]\n        stds = [np.std(all_results[ds_name][algo][metric], ddof=1) if len(all_results[ds_name][algo][metric]) > 1 else 0.0 for algo in [\'ALS\', \'ItemKNN\', \'Pop\']]\n        axes[idx].bar([\'ALS\', \'ItemKNN\', \'Pop\'], vals, yerr=stds, capsize=4)\n        axes[idx].set_title(metric)\n        axes[idx].set_ylim(0, max(0.001, max(vals) * 1.25 if len(vals) else 0.001))\n    fig.suptitle(f\'{ds_name} metrics across seeds\')\n    fig.tight_layout()\n    fig.savefig(os.path.join(working_dir, f\'{ds_name}_seed_sensitivity_metrics.png\'), dpi=150)\n    plt.close(fig)\n\nprint(f\'\\nSaved results to {working_dir}\')\n```', 'Execution Output': '```\nTraceback (most recent call last):\n  File "F:\\Uni\\Semester 6\\ML_Praktikum\\AutoRecLabTeam5\\treesearch\\interpreter.py", line 147, in _run_session\n    exec(compile(code, self.agent_file_name, "exec"), global_scope)\n  File "runfile.py", line 158, in <module>\n  File "runfile.py", line 39, in load_amazon\nValueError: Could not identify rating column in Amazon dataset.\nExecution time: 3 seconds seconds (time limit is an hour).\n```', 'Instructions': ['Carefully analyze the execution output for signs of bugs or failures:', '- Syntax errors, import errors, or runtime exceptions', '- Missing required outputs or metrics', '- Execution timeouts or crashes', 