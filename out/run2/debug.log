ate(train, test, algo_name)\n            algo_runs.append({\'seed\': seed, \'metrics\': metrics})\n            experiment_data[dname][\'metrics\'][\'val\'].append({\'algo\': algo_name, \'seed\': seed, **metrics})\n            experiment_data[dname][\'predictions\'].append({\'algo\': algo_name, \'seed\': seed, \'predictions\': recs.to_dict(\'records\')})\n            experiment_data[dname][\'ground_truth\'].append({\'algo\': algo_name, \'seed\': seed, \'ground_truth\': truth})\n            experiment_data[dname][\'seeds\'].append(seed)\n            print(f\'{dname} | {algo_name} | seed={seed} | \' + \', \'.join([f\'{k}={v:.4f}\' for k, v in metrics.items()]))\n        summary[dname][algo_name] = aggregate_by_seed(algo_runs)\n        raw_results.extend([{\'dataset\': dname, \'algo\': algo_name, **r[\'metrics\']} for r in algo_runs])\n\nfor dname in summary:\n    algos = list(summary[dname].keys())\n    xs = np.arange(len(algos))\n    fig, ax = plt.subplots(figsize=(10, 5))\n    metrics_list = [\'precision@1\', \'precision@5\', \'precision@10\', \'ndcg@1\', \'ndcg@5\', \'ndcg@10\']\n    width = 0.12\n    for i, metric in enumerate(metrics_list):\n        means = [summary[dname][a][metric][\'mean\'] for a in algos]\n        stds = [summary[dname][a][metric][\'std\'] for a in algos]\n        ax.errorbar(xs + (i - 2.5) * width / 2, means, yerr=stds, fmt=\'o\', capsize=3, label=metric)\n    ax.set_xticks(xs)\n    ax.set_xticklabels(algos)\n    ax.set_title(dname)\n    ax.set_ylabel(\'score\')\n    ax.legend(ncol=2, fontsize=8)\n    fig.tight_layout()\n    fig.savefig(os.path.join(working_dir, f\'{dname}_seed_sensitivity.png\'), dpi=150)\n    plt.close(fig)\n\nprint(\'\\n=== Summary across seeds (mean ± std) ===\')\nfor dname in summary:\n    print(f\'\\n{dname}\')\n    for algo in summary[dname]:\n        row = summary[dname][algo]\n        print(algo + \': \' + \'; \'.join([f\'{m}={row[m]["mean"]:.4f}±{row[m]["std"]:.4f}\' for m in sorted(row.keys())]))\n\nprint(\'\\n=== Simple statistical sensitivity analysis ===\')\nfor dname in summary:\n    print(f\'\\n{dname}\')\n    for metric in [\'precision@10\', \'ndcg@10\']:\n        vals = np.array([summary[dname][a][metric][\'values\'] for a in ALGOS], dtype=float)\n        variabilities = vals.std(axis=1, ddof=1)\n        print(f\'{metric}: seed-std by algo \' + \', \'.join([f\'{ALGOS[i]}={variabilities[i]:.4f}\' for i in range(len(ALGOS))]))\n        if vals.shape[1] >= 5:\n            f, p = stats.friedmanchisquare(*[vals[i] for i in range(vals.shape[0])])\n            print(f\'Friedman test over algorithms across seeds: statistic={f:.4f}, p={p:.4g}\')\n\nnp.save(os.path.join(working_dir, \'experiment_data.npy\'), experiment_data)\nnp.save(os.path.join(working_dir, \'summary.npy\'), summary, allow_pickle=True)\nnp.save(os.path.join(working_dir, \'raw_results.npy\'), np.array(raw_results, dtype=object), allow_pickle=True)\nprint(f\'\\nSaved outputs to {working_dir}\')\n\n```', 'Execution Output': '```\nLoading MovieLens100K...\nMovieLens100K: 54413 interactions, 938 users, 1008 items\nTraceback (most recent call last):\n  File "runfile.py", line 113, in make_algo\nTypeError: BiasedMF.__init__() got an unexpected keyword argument \'factors\'\n\nDuring handling of the above exception, another exception occurred:\n\nTraceback (most recent call last):\n  File "F:\\Uni\\Semester 6\\ML_Praktikum\\AutoRecLabTeam5\\treesearch\\interpreter.py", line 147, in _run_session\n    exec(compile(code, self.agent_file_name, "exec"), global_scope)\n  File "runfile.py", line 160, in <module>\n  File "runfile.py", line 125, in evaluate\n  File "runfile.py", line 115, in make_algo\nTypeError: ImplicitMF.__init__() got an unexpected keyword argument \'factors\'\nExecution time: 2 seconds seconds (time limit is an hour).\n```', 'Instructions': ['Carefully analyze the execution output for signs of bugs or failures:', '- Syntax errors, import errors, or runtime exceptions', '- Missing required outputs or metric