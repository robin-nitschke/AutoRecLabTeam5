metrics\': {\'train\': [], \'val\': []}, \'losses\': {\'train\': [], \'val\': []}, \'predictions\': [], \'ground_truth\': [], \'details\': [], \'aggregates\': {}},\\n}\\n\\ndef load_movielens(path=\'u.data\'):\\n    df = pd.read_csv(path, sep=\'\\\\t\', names=[\'user\', \'item\', \'rating\', \'timestamp\'])\\n    df = df[df[\'rating\'] > 3].copy()\\n    return df[[\'user\', \'item\']]\\n\\ndef load_amazon(path=\'VideoGames.csv\'):\\n    df = pd.read_csv(path)\\n    cols = {c.lower(): c for c in df.columns}\\n    user_col = cols.get(\'reviewerid\', cols.get(\'user_id\', list(df.columns)[0]))\\n    item_col = cols.get(\'asin\', cols.get(\'item_id\', list(df.columns)[1]))\\n    rating_col = cols.get(\'overall\', cols.get(\'rating\', None))\\n    if rating_col is None:\\n        raise ValueError(\'Could not identify rating column in Amazon dataset.\')\\n    df = df[[user_col, item_col, rating_col]].copy()\\n    df = df[df[rating_col] > 3].copy()\\n    df.columns = [\'user\', \'item\', \'rating\']\\n    return df[[\'user\', \'item\']]\\n\\ndef load_lastfm(path=\'UserTaggedArtists-timestamps.dat\'):\\n    df = pd.read_csv(path, sep=\'\\\\t\', header=None, names=[\'user\', \'item\', \'tag\', \'timestamp\'], engine=\'python\')\\n    return df[[\'user\', \'item\']].drop_duplicates()\\n\\ndef core_filter(df, user_col=\'user\', item_col=\'item\', min_core=5):\\n    changed = True\\n    while changed:\\n        changed = False\\n        uc = df[user_col].value_counts()\\n        ic = df[item_col].value_counts()\\n        keep_users = uc[uc >= min_core].index\\n        keep_items = ic[ic >= min_core].index\\n        new_df = df[df[user_col].isin(keep_users) & df[item_col].isin(keep_items)].copy()\\n        if len(new_df) != len(df):\\n            changed = True\\n            df = new_df\\n    return df.reset_index(drop=True)\\n\\ndef make_seed_split(data, seed):\\n    return xf.SampleFrac(1, frac=0.8, rng_spec=seed).split(data)\\n\\ndef eval_predictions(test, recs, k_list=(1, 5, 10)):\\n    truth = test.groupby(\'user\')[\'item\'].apply(set).to_dict()\\n    recs = recs[[\'user\', \'item\', \'rank\']].copy()\\n    recs[\'rank\'] = recs[\'rank\'].astype(int)\\n    metrics = {}\\n    for k in k_list:\\n        p_vals, ndcg_vals = [], []\\n        for u, gt_items in truth.items():\\n            user_recs = recs[recs[\'user\'] == u].sort_values(\'rank\').head(k)[\'item\'].tolist()\\n            if not gt_items:\\n                continue\\n            hits = [1 if i in gt_items else 0 for i in user_recs]\\n            p_vals.append(np.sum(hits) / float(k))\\n            dcg = sum(rel / np.log2(idx + 2) for idx, rel in enumerate(hits))\\n            ideal_hits = [1] * min(len(gt_items), k)\\n            idcg = sum(rel / np.log2(idx + 2) for idx, rel in enumerate(ideal_hits))\\n            ndcg_vals.append(dcg / idcg if idcg > 0 else 0.0)\\n        metrics[f\'precision@{k}\'] = float(np.mean(p_vals)) if p_vals else np.nan\\n        metrics[f\'ndcg@{k}\'] = float(np.mean(ndcg_vals)) if ndcg_vals else np.nan\\n    return metrics\\n\\ndef train_and_eval(train, test, seed):\\n    algos = {\\n        \'ALS\': ImplicitMF(features=20, iterations=15, reg=0.1, rng_spec=seed),\\n        \'ItemKNN\': ItemItem(nnbrs=50, min_nbrs=1, min_sim=0.0, center=False),\\n        \'Pop\': Popular(),\\n    }\\n    results = {}\\n    users = test[\'user\'].unique()\\n    for name, algo in algos.items():\\n        algo.fit(train)\\n        recs = batch.recommend(algo, users, 10, train)\\n        results[name] = eval_predictions(test, recs)\\n    return results\\n\\ndef summarize_results(all_results):\\n    rows = []\\n    for ds, algos in all_results.items():\\n        for algo, vals in algos.items():\\n            for metric, arr in vals.items():\\n                rows.append({\\n                    \'dataset\': ds,\\n                    \'algo\': algo,\\n                    \'metric\': metric,\\n                    \'mean\': np.nanmean(arr),\\n                    \'std\': np.nanstd(arr, ddof=1) if len(arr) > 1 else 0.0,\\n                    \'n\': len(arr),\\n                })\\n    return pd.DataFrame(rows)\\n\\ndatasets = {\\n    \'MovieLens100K\': load_movielens(\'u.data\'),\\n    \'AmazonVideoGames\': load_amazon(\'VideoGames.csv\'),\\n    \'LastFM\': load_lastfm(\'UserTaggedArtists-timestamps.dat\'),\\n}\\n\\nfor ds_name, df in datasets.items():\\n    df = core_filter(df)\\n    datasets[ds_name] = df\\n    print(f\'{ds_name}: {len(df)} interactions, {df.user.nunique()} users, {df.item.nunique()} items\')\\n\\nall_results = defaultdict(lambda: defaultdict(lambda: defaultdict(list)))\\nseeds = [11, 22, 33, 44, 55]\\n\\nfor ds_name, df in datasets.items():\\n    for seed in seeds:\\n        split = make_seed_split(df, seed)\\n        if isinstance(split, tuple) and len(split) == 2:\\n            train, test = split\\n        else:\\n            parts = list(split)\\n            train, test = parts[0], parts[1]\\n        split_res = train_and_eval(train, test, seed)\\n        for algo, met in split_res.items():\\n            for metric, val in met.items():\\n                all_results[ds_name][algo][metric].append(val)\\n        experiment_data[ds_name][\'details\'].append({\'seed\': seed, \'n_train\': len(train), \'n_test\': len(test)})\\n        print(f\'Completed {ds_name} seed={seed}\')\\n\\nsummary_df = summarize_results(all_results)\\nprint(\'\\\\nSummary (mean ± std across seeds):\')\\nprint(summary_df.sort_values([\'dataset\', \'algo\', \'metric\']).to_string(index=False))\\n\\nprint(\'\\\\nShort statistical analysis (paired t-tests on seed-wise metric vectors):\')\\nfor ds_name in datasets.keys():\\n    for metric in [\'precision@1\', \'precision@5\', \'precision@10\', \'ndcg@1\', \'ndcg@5\', \'ndcg@10\']:\\n        a = np.array(all_results[ds_name][\'ALS\'][metric])\\n        b = np.array(all_results[ds_name][\'ItemKNN\'][metric])\\n        c = np.array(all_results[ds_name][\'Pop\'][metric])\\n        t_ab = stats.tt