mport train_test_split\nimport matplotlib.pyplot as plt\n\nimport lenskit\nfrom lenskit.data import from_interactions_df\nfrom lenskit import topn\n\n# LensKit imports with fallbacks for 0.14.x API differences\ntry:\n    from lenskit.algorithms.als import BiasedMF as ALS\nexcept Exception:\n    try:\n        from lenskit.algorithms.als import ImplicitMF as ALS\n    except Exception:\n        ALS = None\n\ntry:\n    from lenskit.algorithms.item_knn import ItemKNN\nexcept Exception:\n    try:\n        from lenskit.algorithms.item_knn import ItemItem as ItemKNN\n    except Exception:\n        ItemKNN = None\n\ntry:\n    from lenskit.algorithms.popular import Popular as Pop\nexcept Exception:\n    try:\n        from lenskit.algorithms.basic import Popular as Pop\n    except Exception:\n        Pop = None\n\nnp.random.seed(42)\n\nexperiment_data = {\n    \'MovieLens100K\': {\'metrics\': {\'train\': [], \'val\': []}, \'losses\': {\'train\': [], \'val\': []}, \'predictions\': [], \'ground_truth\': [], \'seeds\': [], \'algorithms\': []},\n    \'AmazonVideoGames\': {\'metrics\': {\'train\': [], \'val\': []}, \'losses\': {\'train\': [], \'val\': []}, \'predictions\': [], \'ground_truth\': [], \'seeds\': [], \'algorithms\': []},\n    \'LastFM\': {\'metrics\': {\'train\': [], \'val\': []}, \'losses\': {\'train\': [], \'val\': []}, \'predictions\': [], \'ground_truth\': [], \'seeds\': [], \'algorithms\': []},\n}\n\ndef read_movielens(path):\n    df = pd.read_csv(path, sep=\'\\t\', names=[\'user\', \'item\', \'rating\', \'timestamp\'], engine=\'python\')\n    df = df[df[\'rating\'] > 3].copy()\n    df[\'rating\'] = 1.0\n    df[\'user\'] = df[\'user\'].astype(str)\n    df[\'item\'] = df[\'item\'].astype(str)\n    return df[[\'user\', \'item\', \'rating\', \'timestamp\']]\n\ndef read_amazon(path):\n    df = pd.read_csv(path)\n    cols = {c.lower(): c for c in df.columns}\n    user_col = cols.get(\'reviewerid\', cols.get(\'user_id\', list(df.columns)[0]))\n    item_col = cols.get(\'asin\', cols.get(\'item_id\', cols.get(\'movieid\', list(df.columns)[1])))\n    rating_col = cols.get(\'overall\', cols.get(\'rating\', None))\n    ts_col = cols.get(\'unixreviewtime\', cols.get(\'timestamp\', None))\n    if rating_col is None:\n        df[\'rating\'] = 1.0\n    else:\n        df = df[df[rating_col] > 3].copy()\n        df[\'rating\'] = 1.0\n    if ts_col is None:\n        df[\'timestamp\'] = np.arange(len(df))\n    else:\n        df[\'timestamp\'] = df[ts_col]\n    df[\'user\'] = df[user_col].astype(str)\n    df[\'item\'] = df[item_col].astype(str)\n    return df[[\'user\', \'item\', \'rating\', \'timestamp\']]\n\ndef read_lastfm(path):\n    df = pd.read_csv(path, sep=\'\\t\', header=None, engine=\'python\')\n    if df.shape[1] >= 3:\n        df = df.iloc[:, :3]\n        df.columns = [\'user\', \'item\', \'timestamp\']\n    else:\n        raise ValueError(\'Unexpected LastFM format\')\n    df[\'rating\'] = 1.0\n    df[\'user\'] = df[\'user\'].astype(str)\n    df[\'item\'] = df[\'item\'].astype(str)\n    return df[[\'user\', \'item\', \'rating\', \'timestamp\']]\n\ndef five_core(df):\n    changed = True\n    while changed:\n        changed = False\n        uc = df[\'user\'].value_counts()\n        ic = df[\'item\'].value_counts()\n        keep = df[\'user\'].isin(uc[uc >= 5].index) & df[\'item\'].isin(ic[ic >= 5].index)\n        if keep.sum() < len(df):\n            df = df[keep].copy()\n            changed = True\n    return df\n\ndef make_holdout(df, seed=0, test_frac=0.2):\n    users = df[\'user\'].unique()\n    tr_users, te_users = train_test_split(users, test_size=test_frac, random_state=seed)\n    train = df[df[\'user\'].isin(tr_users)].copy()\n    test = df[df[\'user\'].isin(te_users)].copy()\n    # ensure test users have at least one train interaction by moving one interaction per test user if needed\n    train_parts = [train]\n    moved = []\n    for u, grp in test.groupby(\'user\'):\n        if len(grp) > 0:\n            moved.append(grp.i