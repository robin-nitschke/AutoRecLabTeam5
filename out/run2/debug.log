om scipy import stats\\nfrom collections import defaultdict\\n\\nimport lenskit as lk\\nfrom lenskit import batch, topn\\nfrom lenskit.algorithms import Recommender\\ntry:\\n    from lenskit.algorithms import als, item_knn, popularity\\nexcept Exception:\\n    from lenskit.algorithms import als, item_knn\\n    from lenskit.algorithms import popularity\\n\\nexperiment_data = {\\n    \'MovieLens100K\': {\'metrics\': {\'train\': [], \'val\': []}, \'losses\': {\'train\': [], \'val\': []}, \'predictions\': [], \'ground_truth\': [], \'seeds\': []},\\n    \'AmazonVideoGames\': {\'metrics\': {\'train\': [], \'val\': []}, \'losses\': {\'train\': [], \'val\': []}, \'predictions\': [], \'ground_truth\': [], \'seeds\': []},\\n    \'LastFM\': {\'metrics\': {\'train\': [], \'val\': []}, \'losses\': {\'train\': [], \'val\': []}, \'predictions\': [], \'ground_truth\': [], \'seeds\': []},\\n}\\n\\nDATASETS = {\\n    \'MovieLens100K\': {\'path\': \'u.data\', \'sep\': \'\\\\t\', \'columns\': [\'user\', \'item\', \'rating\', \'timestamp\'], \'implicit_threshold\': 3},\\n    \'AmazonVideoGames\': {\'path\': \'VideoGames.csv\', \'sep\': \',\', \'columns\': None, \'implicit_threshold\': 3},\\n    \'LastFM\': {\'path\': \'UserTaggedArtists-timestamps.dat\', \'sep\': \'\\\\t\', \'columns\': None, \'implicit_threshold\': None},\\n}\\n\\nSEEDS = [11, 22, 33, 44, 55]\\nKS = [1, 5, 10]\\nALGOS = [\'ALS\', \'ItemKNN\', \'Pop\']\\n\\n\\ndef load_dataset(name, spec):\\n    path = spec[\'path\']\\n    if not os.path.exists(path):\\n        raise FileNotFoundError(path)\\n    if name == \'MovieLens100K\':\\n        df = pd.read_csv(path, sep=\'\\\\t\', names=spec[\'columns\'], engine=\'python\')\\n        df = df[df[\'rating\'] > spec[\'implicit_threshold\']][[\'user\', \'item\']].copy()\\n    elif name == \'AmazonVideoGames\':\\n        df = pd.read_csv(path)\\n        cols = {c.lower(): c for c in df.columns}\\n        ucol = cols.get(\'user_id\', cols.get(\'reviewerID\', None))\\n        icol = cols.get(\'item_id\', cols.get(\'asin\', None))\\n        rcol = cols.get(\'rating\', None)\\n        if ucol is None or icol is None or rcol is None:\\n            raise ValueError(\'Could not infer Amazon columns\')\\n        df = df[[ucol, icol, rcol]].rename(columns={ucol: \'user\', icol: \'item\', rcol: \'rating\'})\\n        df = df[df[\'rating\'] > spec[\'implicit_threshold\']][[\'user\', \'item\']].copy()\\n    else:\\n        df = pd.read_csv(path, sep=\'\\\\t\')\\n        cols = {c.lower(): c for c in df.columns}\\n        ucol = cols.get(\'userid\', cols.get(\'user_id\', None))\\n        icol = cols.get(\'artistid\', cols.get(\'itemid\', cols.get(\'artist_id\', None)))\\n        if ucol is None or icol is None:\\n            raise ValueError(\'Could not infer LastFM columns\')\\n        df = df[[ucol, icol]].rename(columns={ucol: \'user\', icol: \'item\'}).copy()\\n    df = df.dropna().astype({\'user\': str, \'item\': str})\\n    return df\\n\\n\\ndef core_filter(df, min_uc=5, min_ic=5):\\n    changed = True\\n    while changed:\\n        before = len(df)\\n        uc = df[\'user\'].value_counts()\\n        ic = df[\'item\'].value_counts()\\n        df = df[df[\'user\'].isin(uc[uc >= min_uc].index) & df[\'item\'].isin(ic[ic >= min_ic].index)].copy()\\n        changed = len(df) != before\\n    return df\\n\\n\\ndef split_user_holdout(df, seed, test_frac=0.2):\\n    rng = np.random.default_rng(seed)\\n    train_idx, test_idx = [], []\\n    for u, g in df.groupby(\'user\'):\\n        idx = g.index.to_numpy()\\n        n_test = max(1, int(np.ceil(len(idx) * test_frac)))\\n        perm = rng.permutation(idx)\\n        test_idx.extend(perm[:n_test].tolist())\\n        train_idx.extend(perm[n_test:].tolist())\\n    train = df.loc[train_idx].reset_index(drop=True)\\n    test = df.loc[test_idx].reset_index(drop=True)\\n    return train, test\\n\\n\\ndef make_algo(name, train_df):\\n    if name == \'ALS\':\\n        return als.BiasedMF(50, reg=0.1, iterations=15)\\n